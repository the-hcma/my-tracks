# My Tracks — Production Environment Configuration
#
# Copy to .env.production and fill in all required values.
# Generate secrets with: python -c "import secrets; print(secrets.token_urlsafe(50))"

# ── Django ───────────────────────────────────────────────────────────────────
# REQUIRED — a strong random secret key
SECRET_KEY=

# Must be False in production
DEBUG=False

# Comma-separated hostnames/IPs the server will accept requests for
ALLOWED_HOSTS=your.domain.com

# HTTPS origins for CSRF validation
CSRF_TRUSTED_ORIGINS=https://your.domain.com

# Optional — if set, command endpoints require Bearer token auth
# COMMAND_API_KEY=

# ── Database ─────────────────────────────────────────────────────────────────
# Connection URL — determines whether containerized or external postgres is used.
#
# Containerized (default):
#   DATABASE_URL=postgresql://mytracks:<password>@postgres:5432/mytracks
#   Also set POSTGRES_USER, POSTGRES_PASSWORD, POSTGRES_DB below.
#
# External (managed database):
#   DATABASE_URL=postgresql://user:password@your-db-host:5432/mytracks
#   POSTGRES_USER/POSTGRES_PASSWORD/POSTGRES_DB are not needed.
DATABASE_URL=

# Only needed for containerized PostgreSQL (docker-compose.postgres.yml):
POSTGRES_USER=mytracks
POSTGRES_PASSWORD=
POSTGRES_DB=mytracks

# ── Ports (host-side mapping) ────────────────────────────────────────────────
HTTPS_PORT=443
HTTP_PORT=80
MQTT_TLS_PORT=8883

# ── TLS Certificates ────────────────────────────────────────────────────────
# Directory containing fullchain.pem and privkey.pem for nginx HTTPS.
# Default: ./certs (relative to docker-compose.yml)
# CERTS_DIR=./certs
