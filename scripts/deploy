#!/usr/bin/env bash
#
# Deploy my-tracks to a Docker Compose production environment.
#
# Usage:
#   ./deploy              First-time setup: generates secrets, creates env, starts stack
#   ./deploy --update     Pull latest image, run migrations, restart
#   ./deploy --backup     Dump PostgreSQL database to timestamped file
#   ./deploy --status     Show running services
#   ./deploy --stop       Stop the stack
#   ./deploy --logs       Tail logs from all services
#   -h, --help            Show this help message
#
# First-time setup generates .env.production with guided prompts,
# creates TLS certificates (self-signed or bring-your-own), and
# starts the full stack (nginx + my-tracks + optional postgres).

set -euo pipefail

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
readonly script_dir
project_dir="$(cd "$script_dir/.." && pwd)"
readonly project_dir
readonly env_file="$project_dir/.env.production"
readonly certs_dir="$project_dir/certs"
readonly backup_dir="$project_dir/backups"
readonly compose_cmd="docker compose"

compose_files=()

# ── Helpers ──────────────────────────────────────────────────────────────────

die() { echo "Error: $1" >&2; exit 1; }

generate_secret() {
    python3 -c "import secrets; print(secrets.token_urlsafe(50))" 2>/dev/null \
        || openssl rand -base64 48 2>/dev/null \
        || die "Cannot generate secret — install Python 3 or OpenSSL"
}

env_get() {
    local key="$1"
    if [ -f "$env_file" ]; then
        grep -E "^${key}=" "$env_file" 2>/dev/null | head -1 | cut -d= -f2-
    fi
}

is_internal_db() {
    local db_url
    db_url="$(env_get "DATABASE_URL")"
    [[ -z "$db_url" || "$db_url" == *"@postgres:"* ]]
}

setup_compose_files() {
    compose_files=("-f" "$project_dir/production/docker/docker-compose.yml")
    if is_internal_db; then
        compose_files+=("-f" "$project_dir/production/docker/docker-compose.postgres-production.yml")
    fi
}

compose() {
    PROJECT_ENV_FILE="$env_file" $compose_cmd --env-file "$env_file" \
        --project-directory "$project_dir" \
        "${compose_files[@]}" \
        "$@"
}

install_hint() {
    local logical="$1"
    local pkg

    if [[ "$(uname -s)" == "Darwin" ]]; then
        case "$logical" in
            docker)              pkg="docker" ;;
            docker-buildx)       pkg="docker-buildx" ;;
            docker-compose)      pkg="docker-compose" ;;
            *)                   pkg="$logical" ;;
        esac
        echo "brew install $pkg"
    elif command -v apt-get >/dev/null 2>&1; then
        case "$logical" in
            docker)              pkg="docker.io" ;;
            docker-buildx)       pkg="docker-buildx" ;;
            docker-compose)      pkg="docker-compose-v2" ;;
            *)                   pkg="$logical" ;;
        esac
        echo "sudo apt-get install $pkg"
    elif command -v dnf >/dev/null 2>&1; then
        case "$logical" in
            docker)              pkg="docker-ce" ;;
            docker-buildx)       pkg="docker-buildx-plugin" ;;
            docker-compose)      pkg="docker-compose-plugin" ;;
            *)                   pkg="$logical" ;;
        esac
        echo "sudo dnf install $pkg"
    elif command -v pacman >/dev/null 2>&1; then
        case "$logical" in
            docker)              pkg="docker" ;;
            docker-buildx)       pkg="docker-buildx" ;;
            docker-compose)      pkg="docker-compose" ;;
            *)                   pkg="$logical" ;;
        esac
        echo "sudo pacman -S $pkg"
    else
        echo "your package manager to install $logical"
    fi
}

check_prerequisites() {
    local missing=()

    if ! command -v docker >/dev/null 2>&1; then
        missing+=("  • Docker is not installed.
      Install with:  $(install_hint docker)")
    else
        local docker_err docker_reason
        docker_err="$(docker info 2>&1)" || true
        docker_reason="$(echo "$docker_err" | grep -i "error\|cannot connect\|failed to connect\|permission denied\|not allowed\|refused" | head -1 | sed 's/^[[:space:]]*//')" || true
        if [ -n "$docker_reason" ]; then
            if [[ "$(uname -s)" == "Darwin" ]]; then
                missing+=("  • Docker daemon is not reachable.
      $docker_reason

      If you use Colima:         colima start
      If you use Docker Desktop: open -a Docker
      Install a runtime:         brew install colima && colima start")
            elif echo "$docker_err" | grep -qi "permission denied\|not allowed"; then
                missing+=("  • Docker daemon is running but your user lacks permission.
      $docker_reason

      Fix with:      sudo usermod -aG docker \$USER
      Then:          newgrp docker   (or log out and back in)")
            elif command -v systemctl >/dev/null 2>&1; then
                if systemctl is-active docker >/dev/null 2>&1; then
                    missing+=("  • Docker service is active but 'docker info' fails.
      $docker_reason

      Your user may need to be in the 'docker' group:
        sudo usermod -aG docker \$USER
        newgrp docker   (or log out and back in)
      Or check the socket:
        ls -la /var/run/docker.sock")
                elif systemctl list-unit-files docker.service 2>/dev/null | grep -q docker; then
                    missing+=("  • Docker daemon is not running.
      $docker_reason

      Start with:    sudo systemctl start docker
      Enable on boot: sudo systemctl enable docker")
                else
                    missing+=("  • Docker CLI is installed but the Docker Engine service is missing.
      $docker_reason

      Install the full Docker Engine:
        $(install_hint docker)
      Then:          sudo systemctl enable --now docker")
                fi
            else
                missing+=("  • Docker daemon is not reachable.
      $docker_reason

      Start with:    sudo dockerd &
      Or check your init system's service manager.")
            fi
        else
            if ! docker buildx version >/dev/null 2>&1; then
                if [[ "$(uname -s)" == "Darwin" ]]; then
                    missing+=("  • Docker buildx plugin is not installed.
      Install with:  brew install docker-buildx
      Then link:     mkdir -p ~/.docker/cli-plugins && ln -sfn \$(brew --prefix)/bin/docker-buildx ~/.docker/cli-plugins/docker-buildx")
                else
                    missing+=("  • Docker buildx plugin is not installed.
      Install with:  $(install_hint docker-buildx)")
                fi
            fi

            if ! $compose_cmd version >/dev/null 2>&1; then
                missing+=("  • Docker Compose is not installed.
      Install with:  $(install_hint docker-compose)")
            fi
        fi
    fi

    if [ ${#missing[@]} -gt 0 ]; then
        local msg="Missing prerequisites:

"
        for item in "${missing[@]}"; do
            msg+="$item
"
        done
        die "$msg"
    fi
}

# ── Commands ─────────────────────────────────────────────────────────────────

cmd_setup() {
    check_prerequisites

    if [ -f "$env_file" ]; then
        echo "Found existing $env_file"
        read -r -p "Re-run setup? This will overwrite existing config. [y/N] " response
        case "$response" in
            [yY][eE][sS]|[yY]) ;;
            *) echo "Cancelled."; exit 0 ;;
        esac
    fi

    echo ""
    echo "╔══════════════════════════════════════════════════════════════╗"
    echo "║              my-tracks production setup                     ║"
    echo "╚══════════════════════════════════════════════════════════════╝"
    echo ""

    # Domain / hostname
    read -r -p "Server hostname (e.g., mytracks.example.com): " hostname
    [ -z "$hostname" ] && die "Hostname is required"

    # Django SECRET_KEY
    secret_key=$(generate_secret)
    echo "Generated SECRET_KEY."

    # Database
    echo ""
    echo "Database configuration:"
    echo "  1) Containerized PostgreSQL (managed by Docker Compose)"
    echo "  2) External PostgreSQL (provide your own DATABASE_URL)"
    read -r -p "Choose [1]: " db_choice
    db_choice=${db_choice:-1}

    local db_url="" pg_user="" pg_db="" pg_password=""

    if [ "$db_choice" = "2" ]; then
        read -r -p "DATABASE_URL (e.g., postgresql://user:pass@host:5432/dbname): " db_url
        [ -n "$db_url" ] || die "DATABASE_URL cannot be empty"
        echo "Using external database."
    else
        read -r -p "PostgreSQL username [mytracks]: " pg_user
        pg_user=${pg_user:-mytracks}
        read -r -p "PostgreSQL database [mytracks]: " pg_db
        pg_db=${pg_db:-mytracks}
        pg_password=$(generate_secret)
        db_url="postgresql://${pg_user}:${pg_password}@postgres:5432/${pg_db}"
        echo "Generated PostgreSQL password."
    fi

    # Ports
    read -r -p "HTTPS port [443]: " https_port
    https_port=${https_port:-443}
    read -r -p "HTTP port (redirect to HTTPS) [80]: " http_port
    http_port=${http_port:-80}
    read -r -p "MQTT TLS port [8883]: " mqtt_tls_port
    mqtt_tls_port=${mqtt_tls_port:-8883}

    # Command API key (optional)
    read -r -p "Generate Command API key for device polling? [y/N] " gen_api_key
    command_api_key=""
    if [[ "$gen_api_key" =~ ^[yY] ]]; then
        command_api_key=$(generate_secret)
        echo "Generated Command API key."
    fi

    # Write .env.production
    {
        echo "# Generated by ./deploy on $(date -u +"%Y-%m-%d %H:%M UTC")"
        echo "SECRET_KEY=$secret_key"
        echo "DEBUG=False"
        echo "ALLOWED_HOSTS=$hostname"
        echo "CSRF_TRUSTED_ORIGINS=https://$hostname"
        echo "DATABASE_URL=$db_url"
        if [ "$db_choice" != "2" ]; then
            echo "POSTGRES_USER=$pg_user"
            echo "POSTGRES_PASSWORD=$pg_password"
            echo "POSTGRES_DB=$pg_db"
        fi
        echo "HTTPS_PORT=$https_port"
        echo "HTTP_PORT=$http_port"
        echo "MQTT_TLS_PORT=$mqtt_tls_port"
        echo "certs_dir=./certs"
        if [ -n "$command_api_key" ]; then
            echo "COMMAND_API_KEY=$command_api_key"
        fi
    } > "$env_file"

    echo ""
    echo "Wrote $env_file"

    # TLS certificates
    setup_tls_certs

    # Start the stack
    setup_compose_files
    echo ""
    if ! is_internal_db; then
        echo "External database — containerized postgres will NOT be started."
    fi
    echo "Starting the stack..."
    compose up -d

    # Create initial admin user
    echo ""
    echo "Creating initial admin user..."
    read -r -p "Admin username [admin]: " admin_user
    admin_user=${admin_user:-admin}
    read -r -p "Admin email: " admin_email
    compose exec my-tracks python manage.py createsuperuser \
        --username "$admin_user" --email "$admin_email" --noinput 2>/dev/null \
        && echo "Admin user '$admin_user' created (set password via admin panel)." \
        || echo "Admin user may already exist — skipping."

    # Summary
    echo ""
    echo "╔══════════════════════════════════════════════════════════════╗"
    echo "║                    Setup complete!                          ║"
    echo "╚══════════════════════════════════════════════════════════════╝"
    echo ""
    echo "  Web UI:     https://$hostname:$https_port/"
    echo "  MQTT TLS:   $hostname:$mqtt_tls_port"
    echo "  Admin user: $admin_user"
    if [ -n "$command_api_key" ]; then
        echo "  API key:    $command_api_key"
    fi
    echo ""
    echo "  Config:     $env_file"
    echo "  Certs:      $certs_dir/"
    if is_internal_db; then
        echo "  Database:   Containerized PostgreSQL (managed by Docker Compose)"
    else
        echo "  Database:   External (see DATABASE_URL in $env_file)"
    fi
    echo ""
    echo "Next steps:"
    echo "  1. Set admin password: https://$hostname:$https_port/admin/"
    echo "  2. Replace self-signed certs with Let's Encrypt:"
    echo "     $compose_cmd --profile certbot run --rm certbot certonly \\"
    echo "       --webroot -w /var/www/certbot -d $hostname"
    echo "     cp /path/to/letsencrypt/live/$hostname/{fullchain,privkey}.pem $certs_dir/"
    echo "     $compose_cmd exec nginx nginx -s reload"
}

setup_tls_certs() {
    mkdir -p "$certs_dir"

    if [ -f "$certs_dir/fullchain.pem" ] && [ -f "$certs_dir/privkey.pem" ]; then
        echo ""
        echo "TLS certificates already exist in $certs_dir/"
        read -r -p "Replace with new self-signed certificate? [y/N] " response
        case "$response" in
            [yY][eE][sS]|[yY]) ;;
            *) echo "Keeping existing certificates."; return 0 ;;
        esac
    fi

    echo ""
    echo "TLS certificate options:"
    echo "  1) Generate self-signed certificate (quick start)"
    echo "  2) I'll provide my own certificates"
    read -r -p "Choice [1]: " tls_choice
    tls_choice=${tls_choice:-1}

    case "$tls_choice" in
        1)
            echo "Generating self-signed certificate for $hostname..."
            openssl req -x509 -nodes -days 365 -newkey rsa:2048 \
                -keyout "$certs_dir/privkey.pem" \
                -out "$certs_dir/fullchain.pem" \
                -subj "/CN=$hostname" \
                -addext "subjectAltName=DNS:$hostname" \
                2>/dev/null
            echo "Self-signed certificate created (valid 365 days)."
            echo "⚠  Browsers will show a security warning. Replace with Let's Encrypt for production."
            ;;
        2)
            echo ""
            echo "Place your certificates in $certs_dir/:"
            echo "  - fullchain.pem (certificate + intermediates)"
            echo "  - privkey.pem   (private key)"
            echo ""
            read -r -p "Press Enter when certificates are in place..."
            [ -f "$certs_dir/fullchain.pem" ] || die "fullchain.pem not found in $certs_dir/"
            [ -f "$certs_dir/privkey.pem" ] || die "privkey.pem not found in $certs_dir/"
            echo "Certificates found."
            ;;
        *)
            die "Invalid choice: $tls_choice"
            ;;
    esac
}

cmd_update() {
    check_prerequisites
    [ -f "$env_file" ] || die "No $env_file found. Run ./deploy first."
    setup_compose_files

    echo "Pulling latest images..."
    compose pull

    echo "Restarting with new images..."
    compose up -d

    echo "Running migrations..."
    compose exec my-tracks python manage.py migrate --noinput

    echo "Update complete."
}

cmd_backup() {
    check_prerequisites
    [ -f "$env_file" ] || die "No $env_file found. Run ./deploy first."
    setup_compose_files

    if ! is_internal_db; then
        die "Backup via this script is only supported for containerized PostgreSQL.
  For external databases, use your database provider's backup tools."
    fi

    mkdir -p "$backup_dir"
    # shellcheck source=/dev/null
    source "$env_file"
    local timestamp
    timestamp=$(date +"%Y%m%d-%H%M%S")
    local backup_file="$backup_dir/mytracks-$timestamp.sql.gz"

    echo "Backing up database..."
    compose exec -T postgres pg_dump -U "${POSTGRES_USER:-mytracks}" "${POSTGRES_DB:-mytracks}" \
        | gzip > "$backup_file"

    echo "Backup saved to $backup_file"
    echo "Size: $(du -h "$backup_file" | cut -f1)"
}

cmd_status() {
    check_prerequisites
    if [ -f "$env_file" ]; then
        setup_compose_files
        compose ps 2>/dev/null || echo "Stack is not running."
    else
        echo "No $env_file found. Run ./deploy first."
    fi
}

cmd_stop() {
    check_prerequisites
    if [ -f "$env_file" ]; then
        setup_compose_files
    else
        compose_files=("-f" "$project_dir/production/docker/docker-compose.yml")
    fi
    compose down
    echo "Stack stopped."
}

cmd_logs() {
    check_prerequisites
    [ -f "$env_file" ] || die "No $env_file found. Run ./deploy first."
    setup_compose_files
    compose logs -f
}

# ── Main ─────────────────────────────────────────────────────────────────────

case "${1:-}" in
    --update)  cmd_update ;;
    --backup)  cmd_backup ;;
    --status)  cmd_status ;;
    --stop)    cmd_stop ;;
    --logs)    cmd_logs ;;
    -h|--help) sed -n '2,/^$/p' "$0" | sed 's/^# \?//'; exit 0 ;;
    "")        cmd_setup ;;
    *)         die "Unknown option: $1. Run ./deploy --help for usage." ;;
esac
