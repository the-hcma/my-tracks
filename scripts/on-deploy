#!/usr/bin/env bash
# scripts/on-deploy - Build hook called by setup-service before starting/restarting the service.
#
# Runs all build and compile steps required to bring the service up to date.
#
# Exit code contract (required by setup-service):
#   0  — steps were executed; service must be restarted to pick up changes.
#   1  — nothing changed; no restart needed (unused here — always rebuilds for safety).
#   2+ — unexpected failure; setup-service will abort.

set -euo pipefail

_on_deploy_fail() {
    local rc=$?
    echo ""
    echo "❌ on-deploy failed (exit code $rc)"
    echo "   line: ${BASH_LINENO[0]:-unknown}"
    echo "   command: ${BASH_COMMAND:-unknown}"
    echo ""
    exit "$rc"
}
trap _on_deploy_fail ERR

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
repo_dir="$(cd "$script_dir/.." && pwd)"

cd "$repo_dir"

# Shared dependency staleness checks and sync helpers (repository-helpers).
# shellcheck source=/dev/null
on_deploy_deps_source_from_repo "$repo_dir"

# Add uv to PATH if it exists in the standard location
if [[ -d "$HOME/.local/bin" ]]; then
    export PATH="$HOME/.local/bin:$PATH"
fi

# Record the deployed commit SHA so subsequent runs can skip unchanged builds.
# Stored in .git/ so it is never committed and is automatically repo-scoped.
current_sha="$(git rev-parse HEAD 2>/dev/null || true)"
sha_file="$HOME/scratch/my-tracks/on-deploy-sha"

echo "Running on-deploy build steps..."

# Ensure the Python environment exists for this worktree.
on_deploy_deps_bootstrap_python_venv "$repo_dir"

# If the service previously failed to start, clear the failed state so a
# subsequent successful restart doesn't keep showing as failed.
if command -v systemctl &>/dev/null; then
    systemctl --user reset-failed my-tracks.service &>/dev/null || true
fi

# Detect whether we are running from a linked worktree or the primary worktree.
# This must be done before any .env work so we can decide which .env to use.
primary_dir="$(git -C "$repo_dir" worktree list --porcelain | awk 'NR==1{print $2}')"
env_file="$repo_dir/.env"
primary_env="$primary_dir/.env"

# The local systemd service is a development deployment.
# Ensure DEBUG=True and that the public domain is in ALLOWED_HOSTS / CSRF_TRUSTED_ORIGINS.
fqdn="$(hostname --fqdn 2>/dev/null || hostname)"
echo "  Configuring .env for development..."

# Feature worktrees: copy the primary worktree's .env so all manually-configured
# settings (ALLOWED_HOSTS, SECRET_KEY, etc.) carry over without needing to be
# re-entered. DATABASE_URL will be appended below to redirect to the primary db.
if [[ "$repo_dir" != "$primary_dir" ]] && [[ -f "$primary_env" ]]; then
    cp "$primary_env" "$env_file"
    echo "  Copied .env from primary worktree (settings carry over)."
fi

# Resolve the public domain to use for ALLOWED_HOSTS and CSRF_TRUSTED_ORIGINS.
# Priority: PUBLIC_DOMAIN already in .env > interactive prompt > machine FQDN fallback.

# Returns 0 if the domain resolves via DNS, 1 otherwise.
_domain_resolves() {
    local domain="$1"
    getent hosts "$domain" &>/dev/null
}

_get_public_domain() {
    local env_file="$1"
    local fqdn="$2"

    # Already configured — use it.
    if [[ -f "$env_file" ]] && grep -q '^PUBLIC_DOMAIN=' "$env_file"; then
        grep '^PUBLIC_DOMAIN=' "$env_file" | cut -d= -f2-
        return
    fi

    # Non-interactive (e.g. systemd ExecStart): fall back to FQDN silently.
    if [[ ! -t 0 ]]; then
        echo "$fqdn"
        return
    fi

    # Interactive: prompt, validate DNS, and loop until accepted.
    local domain confirmed
    while true; do
        read -r -p "  Public domain for this server (e.g. mytracks.example.com) [${fqdn}]: " domain
        domain="${domain:-$fqdn}"

        if _domain_resolves "$domain"; then
            echo "$domain"
            return
        fi

        # DNS lookup failed — warn and ask what to do.
        echo "  ⚠️  Warning: '$domain' did not resolve via DNS." >&2
        echo "     This may be a typo, or DNS may not be configured yet." >&2
        read -r -p "  (r)e-enter domain / (k)eep it anyway: " confirmed
        case "${confirmed,,}" in
            k|keep) echo "$domain"; return ;;
            *)      ;;  # loop and re-prompt
        esac
    done
}

public_domain="$(_get_public_domain "$env_file" "$fqdn")"

if [[ ! -f "$env_file" ]]; then
    {
        echo "DEBUG=True"
        echo "PUBLIC_DOMAIN=${public_domain}"
        echo "ALLOWED_HOSTS=localhost,127.0.0.1,${public_domain}"
        echo "CSRF_TRUSTED_ORIGINS=https://${public_domain}"
    } > "$env_file"
    echo "  Created .env with DEBUG=True, PUBLIC_DOMAIN=${public_domain}."
else
    if ! grep -q '^DEBUG=' "$env_file"; then
        echo "DEBUG=True" >> "$env_file"
        echo "  Added DEBUG=True to .env."
    elif ! grep -q '^DEBUG=True' "$env_file"; then
        sed -i 's/^DEBUG=.*/DEBUG=True/' "$env_file"
        echo "  Set DEBUG=True in .env."
    else
        echo "  DEBUG=True already set — no change needed."
    fi

    # Persist PUBLIC_DOMAIN so subsequent non-interactive runs reuse it.
    if ! grep -q '^PUBLIC_DOMAIN=' "$env_file"; then
        echo "PUBLIC_DOMAIN=${public_domain}" >> "$env_file"
        echo "  Added PUBLIC_DOMAIN=${public_domain} to .env."
    else
        echo "  PUBLIC_DOMAIN already set — no change needed."
    fi

    if ! grep -q '^ALLOWED_HOSTS=' "$env_file"; then
        echo "ALLOWED_HOSTS=localhost,127.0.0.1,${public_domain}" >> "$env_file"
        echo "  Added ALLOWED_HOSTS to .env."
    elif ! grep -q "^ALLOWED_HOSTS=.*${public_domain}" "$env_file"; then
        sed -i "s/^ALLOWED_HOSTS=\(.*\)/ALLOWED_HOSTS=\1,${public_domain}/" "$env_file"
        echo "  Added ${public_domain} to ALLOWED_HOSTS in .env."
    else
        echo "  ALLOWED_HOSTS up to date — no change needed."
    fi

    # CSRF_TRUSTED_ORIGINS must include the https:// origin so Django accepts
    # requests forwarded by the nginx TLS-terminating proxy.
    csrf_origin="https://${public_domain}"
    if ! grep -q '^CSRF_TRUSTED_ORIGINS=' "$env_file"; then
        echo "CSRF_TRUSTED_ORIGINS=${csrf_origin}" >> "$env_file"
        echo "  Added CSRF_TRUSTED_ORIGINS=${csrf_origin} to .env."
    elif ! grep -q "^CSRF_TRUSTED_ORIGINS=.*${public_domain}" "$env_file"; then
        sed -i "s|^CSRF_TRUSTED_ORIGINS=\(.*\)|CSRF_TRUSTED_ORIGINS=\1,${csrf_origin}|" "$env_file"
        echo "  Added ${csrf_origin} to CSRF_TRUSTED_ORIGINS in .env."
    else
        echo "  CSRF_TRUSTED_ORIGINS up to date — no change needed."
    fi
fi

# Worktree database: when running from a linked worktree, point DATABASE_URL at
# the primary worktree's db.sqlite3 so all worktrees share the same live database.
# Without this, Django resolves db.sqlite3 relative to settings.py inside the
# worktree directory, which won't have any data.
if [[ "$repo_dir" != "$primary_dir" ]]; then
    db_url="sqlite:///${primary_dir}/db.sqlite3"
    if ! grep -q '^DATABASE_URL=' "$env_file"; then
        echo "DATABASE_URL=${db_url}" >> "$env_file"
        echo "  Added DATABASE_URL pointing to primary worktree db."
    elif ! grep -qF "DATABASE_URL=${db_url}" "$env_file"; then
        sed -i "s|^DATABASE_URL=.*|DATABASE_URL=${db_url}|" "$env_file"
        echo "  Updated DATABASE_URL to point to primary worktree db."
    else
        echo "  DATABASE_URL up to date — no change needed."
    fi
    echo "  Using database from main worktree: ${primary_dir}/db.sqlite3"
else
    echo "  Using local database: ${repo_dir}/db.sqlite3"
fi

# Skip the expensive build steps if this commit was already deployed and
# local dependency trees still match the lockfiles.
if [[ -n "$current_sha" ]] && [[ -f "$sha_file" ]] && [[ "$(cat "$sha_file")" == "$current_sha" ]]; then
    if on_deploy_deps_python_env_stale "$repo_dir"; then
        echo "  Python lockfiles newer than .venv — sync required."
    elif [[ -f "$repo_dir/package.json" ]] && on_deploy_deps_pnpm_modules_stale "$repo_dir"; then
        echo "  pnpm lockfiles newer than node_modules — install required."
    else
        echo "  Already deployed at commit ${current_sha:0:7} — skipping build steps."
        echo "on-deploy complete."
        exit 1
    fi
fi

on_deploy_deps_sync_python_frozen "$repo_dir"

# Apply any pending database migrations
echo "  Applying database migrations..."
uv run python manage.py migrate --noinput

# Build frontend TypeScript assets
if [[ -f "package.json" ]]; then
    on_deploy_deps_install_pnpm_frozen "$repo_dir"
    echo "  Building frontend assets..."
    pnpm run build --silent
fi

# Collect static files for WhiteNoise
echo "  Collecting static files..."
uv run python manage.py collectstatic --noinput --clear > /dev/null

# Record the deployed commit so the next run can skip unchanged builds.
if [[ -n "$current_sha" ]]; then
    echo "$current_sha" > "$sha_file"
fi

echo "on-deploy complete."

# Warn if there are no admin (staff) users — the web UI is inaccessible until one is created.
# Use a heredoc to pass Python to manage.py shell — avoids shell-quoting issues with set -u.
# Disable set -e locally so exit code 1 (no admin) doesn't abort the script.
no_admin=false
uv run python manage.py shell 2>/dev/null << 'PYEOF' || no_admin=true
import sys
from django.contrib.auth.models import User
sys.exit(0 if User.objects.filter(is_staff=True).exists() else 1)
PYEOF
if [[ "$no_admin" == true ]]; then
    fqdn="$(hostname --fqdn 2>/dev/null || hostname)"
    port="$(grep -oP '(?<=--http-port )\d+' "$repo_dir/etc/systemd/my-tracks.service" 2>/dev/null || echo 8080)"
    echo ""
    echo "┌─────────────────────────────────────────────────────────────────┐"
    echo "│  First-run setup: no admin user found.                          │"
    echo "│                                                                  │"
    echo "│  Create one now:                                                 │"
    echo "│    uv run python manage.py createsuperuser                       │"
    echo "│                                                                  │"
    echo "│  Then visit the web UI at:                                       │"
    echo "│    http://${fqdn}:${port}/                                        │"
    echo "└─────────────────────────────────────────────────────────────────┘"
    echo ""
fi

# Exit 0: code was rebuilt; service must be restarted to pick up changes.
exit 0
