{
  "name": "my-tracks-frontend",
  "version": "1.0.0",
  "description": "TypeScript frontend for My Tracks OwnTracks backend",
  "private": true,
  "packageManager": "pnpm@10.28.0",
  "scripts": {
    "build": "node dev-tooling/esbuild.config.mjs",
    "build:watch": "node dev-tooling/esbuild.config.mjs --watch",
    "lint": "eslint 'web_ui/static/web_ui/ts/**/*.ts'",
    "lint:fix": "eslint 'web_ui/static/web_ui/ts/**/*.ts' --fix",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/leaflet": "^1.9.8",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "@vitest/coverage-v8": "^4.1.2",
    "esbuild": "^0.28.0",
    "eslint": "^10.2.0",
    "globals": "^17.4.0",
    "jsdom": "^29.0.2",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "leaflet": "^1.9.4",
    "nouislider": "^15.8.1"
  }
}
