# Django settings
#
# For development: copy this file to .env — defaults are safe for local use.
# For production:  set DEBUG=False and configure all required values below.

# REQUIRED in production (DEBUG=False). Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=your-secret-key-change-this-in-production

DEBUG=True

# Comma-separated list of hostnames/IPs the server will accept requests for.
# In development (DEBUG=True), local network IPs are auto-discovered.
ALLOWED_HOSTS=localhost,127.0.0.1

# Database — defaults to SQLite when unset (no config needed for development).
# For production with PostgreSQL, uncomment and configure:
# DATABASE_URL=postgresql://user:password@localhost:5432/mytracks

# CSRF trusted origins — required for HTTPS in production.
# Example: CSRF_TRUSTED_ORIGINS=https://mytracks.example.com
CSRF_TRUSTED_ORIGINS=

# Command API key (optional - if set, command endpoints require Bearer token auth)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# COMMAND_API_KEY=your-api-key-here
