#!/usr/bin/env bash
set -euo pipefail
uv python install 3.14
current="$(uv run python -c 'import sys; print(f"{sys.version_info.major}.{sys.version_info.minor}")')"
required="3.14"
if [[ "$current" != "$required" ]]; then
  echo "Python version mismatch: using $current but required $required"
  exit 1
fi
uv sync --all-extras
