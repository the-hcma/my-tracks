#!/usr/bin/env bash
#
# Local production container tester for my-tracks.
#
# Usage:
#   ./production/scripts/my-tracks-production-container-manager --start
#   ./production/scripts/my-tracks-production-container-manager --start --freshen-up
#   ./production/scripts/my-tracks-production-container-manager --stop
#   -h, --help    Show this help message
#
# --start   Build and launch the full production stack (nginx + my-tracks + postgres)
#           on non-conflicting local ports (8443/8080/8883). Creates .env.production
#           and self-signed certs if they don't exist. Reuses existing .env.production
#           unless --freshen-up is passed.
#
# --stop    Tear down the stack and remove volumes.
#
# --freshen-up  (with --start) Regenerate .env.production and certs from scratch.
#
# --import-sqlite [path]  (with --start) Import a local SQLite database into the
#           containerized PostgreSQL. Defaults to ./db.sqlite3 if no path given.
#           Requires --freshen-up or a fresh start (empty database).

set -euo pipefail

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
readonly script_dir
# prod_dir: the production/ directory (parent of scripts/).
# var/  — persistent state: var/db/ (postgres), var/certs/, var/log/
# run/  — transient, recreated on --start, wiped on --stop
prod_dir="$(cd "$script_dir/.." && pwd)"
readonly prod_dir
project_dir="$(cd "$prod_dir/.." && pwd)"
readonly project_dir
readonly env_file="$project_dir/.env.production"
CERTS_DIR="$prod_dir/var/certs"

readonly default_https_port=8443
readonly default_http_port=8080
readonly default_mqtt_tls_port=8883

# Set to the host-side PostgreSQL Unix socket directory when a socket connection
# is selected during database setup. Used to mount the socket into Docker and to
# write PG_SOCKET_DIR into .env.production.
_pg_socket_dir=""

# ── Helpers ──────────────────────────────────────────────────────────────────

die() { echo "Error: $1" >&2; exit 1; }

info() { echo "==> $1"; }

install_hint() {
    # Return OS-appropriate install command for a given logical package name.
    # Maps logical names to distro-specific package names.
    # Usage: install_hint <logical_name>
    local logical="$1"
    local pkg

    if [[ "$(uname -s)" == "Darwin" ]]; then
        case "$logical" in
            docker)              pkg="docker" ;;
            docker-buildx)       pkg="docker-buildx" ;;
            docker-compose)      pkg="docker-compose" ;;
            *)                   pkg="$logical" ;;
        esac
        echo "brew install $pkg"
    elif command -v apt-get >/dev/null 2>&1; then
        case "$logical" in
            docker)              pkg="docker.io" ;;
            docker-buildx)       pkg="docker-buildx" ;;
            docker-compose)      pkg="docker-compose-v2" ;;
            *)                   pkg="$logical" ;;
        esac
        echo "sudo apt-get install $pkg"
    elif command -v dnf >/dev/null 2>&1; then
        case "$logical" in
            docker)              pkg="docker-ce" ;;
            docker-buildx)       pkg="docker-buildx-plugin" ;;
            docker-compose)      pkg="docker-compose-plugin" ;;
            podman)              pkg="podman" ;;
            podman-compose)      pkg="podman-compose" ;;
            *)                   pkg="$logical" ;;
        esac
        echo "sudo dnf install $pkg"
    elif command -v pacman >/dev/null 2>&1; then
        case "$logical" in
            docker)              pkg="docker" ;;
            docker-buildx)       pkg="docker-buildx" ;;
            docker-compose)      pkg="docker-compose" ;;
            *)                   pkg="$logical" ;;
        esac
        echo "sudo pacman -S $pkg"
    else
        echo "your package manager to install $logical"
    fi
}

detect_compose_cmd() {
    local engine="${1:-docker}"
    if [ "$engine" = "podman" ]; then
        if podman compose version >/dev/null 2>&1; then
            echo "podman compose"
        elif command -v podman-compose >/dev/null 2>&1; then
            echo "podman-compose"
        else
            die "Neither 'podman compose' nor 'podman-compose' found.
  Install with:  $(install_hint podman-compose)"
        fi
    else
        if docker compose version >/dev/null 2>&1; then
            echo "docker compose"
        elif command -v docker-compose >/dev/null 2>&1; then
            echo "docker-compose"
        else
            die "Neither 'docker compose' (plugin) nor 'docker-compose' (standalone) found.
  Install with:  $(install_hint docker-compose)"
        fi
    fi
}

generate_secret() {
    # No Python required — openssl is standard on macOS and most Linux distros.
    openssl rand -base64 48 2>/dev/null \
        || LC_ALL=C tr -dc 'A-Za-z0-9_-' < /dev/urandom 2>/dev/null | head -c 67 \
        || die "Cannot generate secret — install OpenSSL or ensure /dev/urandom is available"
}

compose_cmd=""
compose_files=()
container_engine=""  # "docker" or "podman"

check_prerequisites() {
    local missing=()

    # ── Container engine (Docker preferred, Podman as fallback) ──────────
    if command -v docker >/dev/null 2>&1; then
        container_engine="docker"

        # ── Docker daemon reachable? ──────────────────────────────────────
        local docker_err docker_reason
        docker_err="$(docker info 2>&1)" || true
        docker_reason="$(echo "$docker_err" | grep -i "error\|cannot connect\|failed to connect\|permission denied\|not allowed\|refused" | head -1 | sed 's/^[[:space:]]*//')" || true
        if [ -n "$docker_reason" ]; then
            if [[ "$(uname -s)" == "Darwin" ]]; then
                missing+=("  • Docker daemon is not reachable.
      $docker_reason

      If you use Colima:         colima start
      If you use Docker Desktop: open -a Docker
      Install a runtime:         brew install colima && colima start")
            elif echo "$docker_err" | grep -qi "permission denied\|not allowed"; then
                missing+=("  • Docker daemon is running but your user lacks permission.
      $docker_reason

      Fix with:      sudo usermod -aG docker \$USER
      Then:          newgrp docker   (or log out and back in)")
            elif command -v systemctl >/dev/null 2>&1; then
                if systemctl is-active docker >/dev/null 2>&1; then
                    missing+=("  • Docker service is active but 'docker info' fails.
      $docker_reason

      Your user may need to be in the 'docker' group:
        sudo usermod -aG docker \$USER
        newgrp docker   (or log out and back in)
      Or check the socket:
        ls -la /var/run/docker.sock")
                elif systemctl list-unit-files docker.service 2>/dev/null | grep -q docker; then
                    missing+=("  • Docker daemon is not running.
      $docker_reason

      Start with:    sudo systemctl start docker
      Enable on boot: sudo systemctl enable docker")
                else
                    missing+=("  • Docker CLI is installed but the Docker Engine service is missing.
      $docker_reason

      Install the full Docker Engine:
        $(install_hint docker)
      Then:          sudo systemctl enable --now docker")
                fi
            else
                missing+=("  • Docker daemon is not reachable.
      $docker_reason

      Start with:    sudo dockerd &
      Or check your init system's service manager.")
            fi
        else
            # Docker daemon is OK — check buildx and compose
            if ! docker buildx version >/dev/null 2>&1; then
                if [[ "$(uname -s)" == "Darwin" ]]; then
                    missing+=("  • Docker buildx plugin is not installed.
      Install with:  brew install docker-buildx
      Then link:     mkdir -p ~/.docker/cli-plugins && ln -sfn \$(brew --prefix)/bin/docker-buildx ~/.docker/cli-plugins/docker-buildx")
                else
                    missing+=("  • Docker buildx plugin is not installed.
      Install with:  $(install_hint docker-buildx)")
                fi
            fi

            if ! docker compose version >/dev/null 2>&1 && ! command -v docker-compose >/dev/null 2>&1; then
                missing+=("  • Docker Compose is not installed.
      Install with:  $(install_hint docker-compose)")
            else
                compose_cmd="$(detect_compose_cmd docker)"
            fi
        fi

    elif command -v podman >/dev/null 2>&1; then
        container_engine="podman"

        # Podman is daemonless — no daemon check needed.
        # Podman has built-in build support — no buildx check needed.

        # Verify rootless user namespace subordinate ID ranges are configured.
        # Required for image builds: layer extraction maps container UIDs (e.g. uid 42
        # for /etc/gshadow) through the host subuid/subgid range.  podman unshare is
        # too shallow a test — it passes even when the range is absent or too narrow.
        local cur_user
        cur_user="$(id -un)"
        local subuid_count subgid_count
        subuid_count="$(grep -E "^${cur_user}:" /etc/subuid 2>/dev/null | head -1 | cut -d: -f3 || true)"
        subgid_count="$(grep -E "^${cur_user}:" /etc/subgid 2>/dev/null | head -1 | cut -d: -f3 || true)"
        if [ -z "$subuid_count" ] || [ "$subuid_count" -lt 65536 ] \
        || [ -z "$subgid_count" ] || [ "$subgid_count" -lt 65536 ]; then
            missing+=("  • Podman subordinate UID/GID ranges not configured (required to build images).
      Current /etc/subuid entry for ${cur_user}: ${subuid_count:-(none)}
      Current /etc/subgid entry for ${cur_user}: ${subgid_count:-(none)}

      Fix:
        echo \"${cur_user}:100000:65536\" | sudo tee -a /etc/subuid
        echo \"${cur_user}:100000:65536\" | sudo tee -a /etc/subgid
        podman system migrate
      Then re-run this script.")
        fi

        if podman compose version >/dev/null 2>&1 || command -v podman-compose >/dev/null 2>&1; then
            compose_cmd="$(detect_compose_cmd podman)"
        else
            missing+=("  • podman-compose is not installed (required for multi-container stack).
      Install with:  $(install_hint podman-compose)")
        fi

    else
        # Neither Docker nor Podman found
        if command -v dnf >/dev/null 2>&1; then
            missing+=("  • Neither Docker nor Podman is installed.
      Podman (available in default repos):
        sudo dnf install -y podman podman-compose
      Or Docker Engine:
        sudo dnf install -y yum-utils
        sudo yum-config-manager --add-repo https://download.docker.com/linux/centos/docker-ce.repo
        sudo dnf install docker-ce docker-ce-cli containerd.io docker-buildx-plugin docker-compose-plugin
        sudo systemctl enable --now docker")
        else
            missing+=("  • Neither Docker nor Podman is installed.
      Install Docker with:  $(install_hint docker)
      Or Podman with:       $(install_hint podman)")
        fi
    fi

    # ── Other tools ──────────────────────────────────────────────────────
    if ! command -v curl >/dev/null 2>&1; then
        missing+=("  • curl is not installed (required for health checks).
      Install with:  $(install_hint curl)")
    fi

    if ! command -v openssl >/dev/null 2>&1; then
        missing+=("  • openssl is not installed (required for TLS certificate generation).
      Install with:  $(install_hint openssl)")
    fi

    # ── Report all issues at once ────────────────────────────────────────
    if [ ${#missing[@]} -gt 0 ]; then
        local msg="Missing prerequisites:

"
        for item in "${missing[@]}"; do
            msg+="$item
"
        done
        die "$msg"
    fi
}

env_get() {
    local key="$1"
    if [ -f "$env_file" ]; then
        grep -E "^${key}=" "$env_file" 2>/dev/null | head -1 | cut -d= -f2- || true
    fi
}

is_internal_db() {
    local db_url
    db_url="$(env_get "DATABASE_URL")"
    [[ -z "$db_url" || "$db_url" == *"@postgres:"* ]]
}

is_persistent_internal_db() {
    [ "$(env_get "POSTGRES_MODE")" = "persistent" ]
}

# True when persistent mode is active AND the data directory exists.
# Does NOT inspect contents — after postgres initialises the directory it
# becomes owned by the container's postgres UID (remapped on the host via
# user namespaces), so the host user cannot list or chmod it.
has_persistent_pg_data() {
    local data_dir
    data_dir="$(env_get "POSTGRES_DATA_DIR")"
    is_persistent_internal_db \
        && [ -n "$data_dir" ] \
        && [ -d "$data_dir" ]
}

# Remove empty subdirectories under var/, then var/ itself if empty.
# Uses rmdir directly — it is a no-op on non-empty directories, so it is safe
# even for dirs like var/db/ that are owned by a remapped container UID and
# cannot be inspected by the host user (ls -A would falsely report empty).
cleanup_empty_var_dirs() {
    local var_dir="$prod_dir/var"
    [ -d "$var_dir" ] || return 0
    for subdir in "$var_dir"/*/; do
        [ -d "$subdir" ] || continue
        rmdir "$subdir" 2>/dev/null || true
    done
    rmdir "$var_dir" 2>/dev/null || true
}

# Try to remove a path (file or directory).  On failure, append a message to
# _removal_errors rather than aborting — callers must check _removal_errors
# afterward and report them.
_removal_errors=()
try_rm() {
    local label="$1" path="$2"
    local out
    if ! out=$(rm -rf "$path" 2>&1); then
        _removal_errors+=("  ✗ Failed to remove $label ($path): $out")
    fi
}

# Flush collected removal errors to stderr and return non-zero if any exist.
flush_removal_errors() {
    [ "${#_removal_errors[@]}" -eq 0 ] && return 0
    echo "" >&2
    echo "  ── Removal errors (manual cleanup may be required) ──" >&2
    for msg in "${_removal_errors[@]}"; do
        echo "$msg" >&2
    done
    return 1
}

setup_compose_files() {
    compose_files=("-f" "$project_dir/docker-compose.yml")
    if is_internal_db; then
        if is_persistent_internal_db; then
            compose_files+=("-f" "$project_dir/docker-compose.postgres-production.yml")
        else
            compose_files+=("-f" "$project_dir/docker-compose.postgres-testing.yml")
        fi
    elif [ -n "$(env_get "PG_SOCKET_DIR")" ]; then
        compose_files+=("-f" "$project_dir/docker-compose.socket.yml")
    fi
}

compose() {
    # podman-compose does not support --project-directory; it uses the compose
    # file's own directory as the base (correct since we pass absolute -f paths).
    if [ "$container_engine" = "podman" ]; then
        $compose_cmd --env-file "$env_file" \
            "${compose_files[@]}" \
            "$@"
    else
        $compose_cmd --env-file "$env_file" \
            "${compose_files[@]}" \
            --project-directory "$project_dir" \
            "$@"
    fi
}

mask_password_in_url() {
    local url="$1"
    echo "$url" | sed -E 's|(://[^:]+:)[^@]+(@)|\1***\2|'
}

# Percent-encode a string for safe embedding in a URL (e.g. password with @/:).
# Pure bash — no Python required.
urlencode() {
    local string="$1" encoded="" i char
    for (( i=0; i<${#string}; i++ )); do
        char="${string:i:1}"
        case "$char" in
            [A-Za-z0-9._~-]) encoded+="$char" ;;
            *) printf -v char '%%%02X' "'$char"; encoded+="$char" ;;
        esac
    done
    printf '%s\n' "$encoded"
}

# Percent-decode a URL-encoded string.
# Pure bash — no Python required.
urldecode() {
    printf '%b\n' "${1//%/\\x}"
}

# Parse a postgresql:// or postgres:// URL into named variables.
# Sets: _db_user _db_password _db_host _db_port _db_name _db_socket
# All values are percent-decoded. _db_socket is set from the ?host= query param
# (used for Unix socket URLs). Pure bash — no Python required.
parse_db_url() {
    local url="$1"
    local rest="${url#postgresql://}"
    rest="${rest#postgres://}"

    # Extract userinfo (everything before the last @ before the host)
    local userinfo=""
    if [[ "$rest" == *"@"* ]]; then
        userinfo="${rest%%@*}"
        rest="${rest#*@}"
    fi

    # Extract dbname + optional query string (everything after the first /)
    local dbpart=""
    if [[ "$rest" == *"/"* ]]; then
        dbpart="${rest#*/}"
        rest="${rest%%/*}"
    fi
    local hostpart="$rest"

    # Parse user and password from userinfo
    if [[ "$userinfo" == *":"* ]]; then
        _db_user="$(urldecode "${userinfo%%:*}")"
        _db_password="$(urldecode "${userinfo#*:}")"
    else
        _db_user="$(urldecode "$userinfo")"
        _db_password=""
    fi

    # Parse host and port
    if [[ "$hostpart" == *":"* ]]; then
        _db_host="${hostpart%%:*}"
        _db_port="${hostpart#*:}"
    else
        _db_host="$hostpart"
        _db_port="5432"
    fi
    _db_port="${_db_port:-5432}"

    # Separate dbname from query string
    local querystring=""
    if [[ "$dbpart" == *"?"* ]]; then
        querystring="${dbpart#*\?}"
        dbpart="${dbpart%%\?*}"
    fi
    _db_name="$(urldecode "$dbpart")"

    # Extract socket path from ?host= query param (Unix socket URLs)
    _db_socket=""
    if [[ "$querystring" == *"host="* ]]; then
        local hostval="${querystring#*host=}"
        hostval="${hostval%%&*}"
        _db_socket="$(urldecode "$hostval")"
    fi
}

# Print the shell prefix needed to run a postgres admin command on this platform.
# macOS (Homebrew): commands run as the current user — no prefix needed.
# Linux: must switch to the postgres system user.
_pg_admin_prefix() {
    if [[ "$(uname -s)" == "Darwin" ]]; then
        echo ""
    else
        echo "sudo su - postgres -c "
    fi
}

# Print a single postgres admin command formatted for this platform.
# On Linux wraps it in: sudo su - postgres -c "cmd"
_pg_admin_cmd() {
    local cmd="$1"
    if [[ "$(uname -s)" == "Darwin" ]]; then
        echo "    $cmd"
    else
        # Inner double-quotes inside the outer ones need escaping.
        local escaped="${cmd//\"/\\\"}"
        echo "    sudo su - postgres -c \"$escaped\""
    fi
}

# Print platform-appropriate instructions for upgrading PostgreSQL to a supported
# version (14+). All output goes to stderr so this is safe inside $() subshells.
_show_pg_upgrade_instructions() {
    echo "     Install a supported version (PostgreSQL 14+):" >&2
    echo "" >&2
    local os; os="$(uname -s)"
    if [[ "$os" == "Darwin" ]]; then
        echo "       brew install postgresql@17" >&2
        echo "       brew services start postgresql@17" >&2
    elif command -v apt-get >/dev/null 2>&1; then
        # Debian/Ubuntu: use the official PGDG apt repository
        echo "       sudo apt-get install -y curl ca-certificates" >&2
        echo "       sudo install -d /usr/share/postgresql-common/pgdg" >&2
        echo "       sudo curl -o /usr/share/postgresql-common/pgdg/apt.postgresql.org.asc --fail \\" >&2
        echo "           https://www.postgresql.org/media/keys/ACCC4CF8.asc" >&2
        echo "       sudo sh -c 'echo \"deb [signed-by=/usr/share/postgresql-common/pgdg/apt.postgresql.org.asc] \\" >&2
        echo "           https://apt.postgresql.org/pub/repos/apt \$(lsb_release -cs)-pgdg main\" \\" >&2
        echo "           > /etc/apt/sources.list.d/pgdg.list'" >&2
        echo "       sudo apt-get update && sudo apt-get install -y postgresql-17" >&2
        echo "       sudo systemctl enable --now postgresql@17-main" >&2
    elif command -v dnf >/dev/null 2>&1; then
        # RHEL/CentOS/Fedora: use the PGDG RPM repository
        echo "       sudo dnf install -y https://download.postgresql.org/pub/repos/yum/reporpms/EL-8-x86_64/pgdg-redhat-repo-latest.noarch.rpm" >&2
        echo "       sudo dnf -qy module disable postgresql" >&2
        echo "       sudo dnf install -y postgresql17-server" >&2
        echo "       sudo /usr/pgsql-17/bin/postgresql-17-setup initdb" >&2
        echo "       sudo systemctl enable --now postgresql-17" >&2
    elif command -v pacman >/dev/null 2>&1; then
        # Arch: official repos always carry the latest version
        echo "       sudo pacman -S postgresql" >&2
        echo "       sudo -u postgres initdb -D /var/lib/postgres/data" >&2
        echo "       sudo systemctl enable --now postgresql" >&2
    else
        echo "       Install PostgreSQL 14 or later using your system's package manager." >&2
        echo "       Official packages: https://www.postgresql.org/download/" >&2
    fi
    echo "" >&2
    echo "     Then re-run this script to set up the database user and connection." >&2
}

# Check the installed PostgreSQL server version without connecting or authenticating.
# Tries pg_lsclusters (Debian/Ubuntu), the postgres binary in PATH, and versioned
# binary paths (RHEL/CentOS). Returns 1 and prints upgrade instructions if version < 14;
# returns 0 if version is acceptable or cannot be determined without credentials.
_early_pg_version_check() {
    local major_ver=""

    # Debian/Ubuntu: pg_lsclusters lists installed clusters with version numbers
    if command -v pg_lsclusters >/dev/null 2>&1; then
        major_ver=$(pg_lsclusters -h 2>/dev/null | awk '{print $1}' | sort -n | tail -1)
    fi

    # postgres binary may be in PATH (macOS Homebrew, Arch, some RHEL configs)
    if [ -z "$major_ver" ] && command -v postgres >/dev/null 2>&1; then
        major_ver=$(postgres --version 2>/dev/null | grep -oE '\b[0-9]+\b' | head -1)
    fi

    # RHEL/CentOS/Fedora: versioned binaries under /usr/pgsql-XX/bin/
    if [ -z "$major_ver" ]; then
        local bin
        for bin in /usr/pgsql-*/bin/postgres; do
            [ -x "$bin" ] || continue
            major_ver=$("$bin" --version 2>/dev/null | grep -oE '\b[0-9]+\b' | head -1)
            break
        done
    fi

    [ -z "$major_ver" ] && return 0  # can't determine without connecting — deferred to probe_db_connection

    if [ "$major_ver" -lt 14 ]; then
        _pg_bad_version="$major_ver"   # exposed for callers that want it in error messages
        echo "" >&2
        echo "  ✘  PostgreSQL $major_ver is installed but not supported (Django requires 14+)." >&2
        _show_pg_upgrade_instructions
        return 1
    fi
    return 0
}

# Scan common PostgreSQL Unix socket locations for a live .s.PGSQL.5432 socket.
# Outputs the directory path to stdout; returns 1 if none found.
detect_pg_socket_dir() {
    local dir
    for dir in /var/run/postgresql /run/postgresql /tmp; do
        if [ -S "${dir}/.s.PGSQL.5432" ]; then
            echo "$dir"
            return 0
        fi
    done
    return 1
}

# Run psql with the password stored in a temporary .pgpass file (mode 0600).
# The password is never placed in argv or in the process environment (PGPASSWORD
# is visible to any process that can read /proc/<pid>/environ on Linux).
# Runs in a subshell so the EXIT trap fires on any exit — including Ctrl+C —
# without interfering with the parent script's signal handlers.
# Usage: _run_psql <password> <psql-args...>
_run_psql() {
    local password="$1"
    shift
    (
        local pgpass_file
        pgpass_file="$(mktemp)" || exit 1
        # shellcheck disable=SC2064
        trap "rm -f '$pgpass_file'" EXIT
        chmod 0600 "$pgpass_file"
        printf '*:*:*:*:%s\n' "$password" > "$pgpass_file"
        PGPASSFILE="$pgpass_file" PGCONNECT_TIMEOUT=5 psql "$@"
    )
}

# Run psql inside a throwaway postgres:17-alpine container — no local psql needed.
# Password is passed via a temp .pgpass file mounted read-only into the container.
# Extra docker flags (e.g. --network host, -v ...) are separated from psql args
# by a -- sentinel: _docker_psql <password> [<docker-flags...> --] <psql-args...>
_docker_psql() {
    local password="$1"; shift
    local extra_docker_args=()
    while [[ $# -gt 0 && "$1" != "--" ]]; do
        extra_docker_args+=("$1"); shift
    done
    [[ "${1:-}" == "--" ]] && shift
    (
        local pgpass_file
        pgpass_file="$(mktemp)" || exit 1
        # shellcheck disable=SC2064
        trap "rm -f '$pgpass_file'" EXIT
        chmod 0600 "$pgpass_file"
        printf '*:*:*:*:%s\n' "$password" > "$pgpass_file"
        "${container_engine:-docker}" run --rm \
            -v "$pgpass_file:/tmp/.pgpass:ro" \
            -e PGPASSFILE=/tmp/.pgpass \
            -e PGCONNECT_TIMEOUT=5 \
            "${extra_docker_args[@]}" \
            docker.io/library/postgres:17-alpine \
            psql "$@"
    )
}

# Probe a PostgreSQL DATABASE_URL for connectivity and authentication.
# Uses pg_isready for a fast network check, then psql for a full auth test.
# Captures psql stderr to diagnose specific failures (missing user, missing
# database, wrong password, pg_hba rejection) and prints targeted fix commands.
# host.docker.internal is rewritten to localhost since the probe runs on the host.
# For Unix socket URLs (empty hostname, ?host=/socket/path), accepts an optional
# second argument with the host-side socket directory to use for the probe.
# All output goes to stderr so this function is safe inside $() subshells.
# Returns 0 on success, 1 on confirmed failure.
probe_db_connection() {
    local url="$1"
    # Optional: host-side socket directory, used when url contains the container
    # socket path (/var/run/postgresql) but the host socket may be elsewhere.
    local socket_dir_hint="${2:-}"
    local masked; masked="$(mask_password_in_url "$url")"
    echo "==> Probing database: $masked" >&2

    # host.docker.internal only resolves inside a container; probe uses localhost.
    local probe_url="${url/host.docker.internal/localhost}"

    # Extract connection fields for targeted error messages and the docker probe.
    # Pure bash URL parsing — no Python required.
    local probe_host probe_port pg_user pg_password pg_db
    parse_db_url "$probe_url"
    probe_host="$_db_host"
    probe_port="$_db_port"
    pg_user="$_db_user"
    pg_password="$_db_password"
    pg_db="$_db_name"

    # Detect Unix socket URLs: hostname is empty and ?host= query param names socket dir.
    local is_socket="false"
    if [ -z "$probe_host" ]; then
        is_socket="true"
        if [ -n "$socket_dir_hint" ]; then
            probe_host="$socket_dir_hint"
        else
            probe_host="${_db_socket:-$(env_get "PG_SOCKET_DIR" 2>/dev/null || true)}"
            probe_host="${probe_host:-/var/run/postgresql}"
        fi
    fi

    # Fast connectivity pre-flight — pure bash, no external tools.
    if [ "$is_socket" = "true" ]; then
        if [ ! -S "$probe_host/.s.PGSQL.${probe_port:-5432}" ]; then
            echo "  ✘  Cannot reach PostgreSQL at socket $probe_host — check that PostgreSQL is running." >&2
            return 1
        fi
    else
        # shellcheck disable=SC2188
        if ! (>/dev/tcp/"$probe_host"/"$probe_port") 2>/dev/null; then
            echo "  ✘  Cannot reach PostgreSQL at ${probe_host}:${probe_port} — check host, port, and firewall." >&2
            return 1
        fi
    fi

    # Full auth + version check via Docker — no local psql required.
    # Build docker flags and determine the host psql should connect to.
    local docker_flags=()
    local psql_host="$probe_host"
    if [ "$is_socket" = "true" ]; then
        docker_flags+=("-v" "$probe_host:$probe_host")
    elif [[ "$probe_host" == "localhost" || "$probe_host" == "127.0.0.1" || "$probe_host" == "::1" ]]; then
        if [[ "$(uname -s)" == "Linux" ]]; then
            docker_flags+=("--network" "host")
        else
            # macOS Docker Desktop: 'localhost' inside a container is the container itself.
            psql_host="host.docker.internal"
        fi
    fi

    local psql_out psql_rc
    # Password stored in a temp .pgpass file mounted read-only into the container.
    if [ "$is_socket" = "true" ]; then
        psql_out="$(_docker_psql "$pg_password" "${docker_flags[@]}" -- \
            -h "$probe_host" -U "$pg_user" -d "$pg_db" \
            -c "SELECT 1" 2>&1)"
    else
        psql_out="$(_docker_psql "$pg_password" "${docker_flags[@]}" -- \
            -h "$psql_host" -p "$probe_port" -U "$pg_user" -d "$pg_db" \
            -c "SELECT 1" 2>&1)"
    fi
    psql_rc=$?
    if [ "$psql_rc" -eq 0 ]; then
        # Verify PostgreSQL version — Django 5+ requires PostgreSQL 14 or later.
        local pg_ver_num pg_ver_display
        if [ "$is_socket" = "true" ]; then
            pg_ver_num="$(_docker_psql "$pg_password" "${docker_flags[@]}" -- \
                -h "$probe_host" -U "$pg_user" -d "$pg_db" \
                -t -c 'SHOW server_version_num;' 2>/dev/null | tr -d ' \n')"
            pg_ver_display="$(_docker_psql "$pg_password" "${docker_flags[@]}" -- \
                -h "$probe_host" -U "$pg_user" -d "$pg_db" \
                -t -c 'SHOW server_version;' 2>/dev/null | tr -d ' \n')"
        else
            pg_ver_num="$(_docker_psql "$pg_password" "${docker_flags[@]}" -- \
                -h "$psql_host" -p "$probe_port" -U "$pg_user" -d "$pg_db" \
                -t -c 'SHOW server_version_num;' 2>/dev/null | tr -d ' \n')"
            pg_ver_display="$(_docker_psql "$pg_password" "${docker_flags[@]}" -- \
                -h "$psql_host" -p "$probe_port" -U "$pg_user" -d "$pg_db" \
                -t -c 'SHOW server_version;' 2>/dev/null | tr -d ' \n')"
        fi
            if [ -n "$pg_ver_num" ] && [ "$pg_ver_num" -lt 140000 ] 2>/dev/null; then
                echo "  ✘  PostgreSQL ${pg_ver_display} is too old — Django requires PostgreSQL 14 or later." >&2
                _show_pg_upgrade_instructions >&2
                return 1
            fi
            return 0
        fi
        # Diagnose the specific failure and show targeted fix commands.
        # Passwords are never embedded in commands — \password prompts interactively.
        if echo "$psql_out" | grep -qi "role.*does not exist"; then
            echo "  ✘  PostgreSQL user '$pg_user' does not exist." >&2
            echo "     Create it and set a password (you will be prompted):" >&2
            _pg_admin_cmd "createuser -s $pg_user" >&2
            _pg_admin_cmd "psql -c '\\password $pg_user'" >&2
        elif echo "$psql_out" | grep -qi "database.*does not exist"; then
            echo "  ✘  Database '$pg_db' does not exist." >&2
            echo "     Create it with:" >&2
            _pg_admin_cmd "createdb -O $pg_user $pg_db" >&2
        elif echo "$psql_out" | grep -qi "password authentication failed\|authentication failed"; then
            echo "  ✘  Authentication failed for user '$pg_user'." >&2
            echo "     This is either a wrong password or a mismatch between pg_hba.conf" >&2
            echo "     auth method and the password hash stored in PostgreSQL." >&2
            echo "" >&2
            echo "     Step 1 — check the password encryption setting:" >&2
            _pg_admin_cmd "psql -c 'SHOW password_encryption;'" >&2
            echo "" >&2
            if [ "$is_socket" = "true" ]; then
                echo "     Step 2 — ensure pg_hba.conf has a 'local' entry (Unix socket) whose" >&2
                echo "     auth method matches the result of Step 1. Add/update for '${pg_db}'" >&2
                echo "     and '${pg_user}' — use whichever method Step 1 showed:" >&2
                echo "       local   ${pg_db}   ${pg_user}   scram-sha-256   # if password_encryption=scram-sha-256" >&2
                echo "       local   ${pg_db}   ${pg_user}   md5             # if password_encryption=md5" >&2
                echo "     To find pg_hba.conf:" >&2
                _pg_admin_cmd "psql -c 'SHOW hba_file;'" >&2
                echo "     Then reload:" >&2
            else
                echo "     Step 2 — ensure pg_hba.conf has a 'host' entry whose auth method" >&2
                echo "     matches the result of Step 1. Add/update for '${pg_db}' and" >&2
                echo "     '${pg_user}' — use whichever method Step 1 showed:" >&2
                echo "       host   ${pg_db}   ${pg_user}   127.0.0.1/32   scram-sha-256   # if password_encryption=scram-sha-256" >&2
                echo "       host   ${pg_db}   ${pg_user}   127.0.0.1/32   md5             # if password_encryption=md5" >&2
                echo "     To find pg_hba.conf:" >&2
                _pg_admin_cmd "psql -c 'SHOW hba_file;'" >&2
                echo "     Then reload:" >&2
            fi >&2
            _pg_admin_cmd "psql -c 'SELECT pg_reload_conf();'" >&2
            echo "" >&2
            echo "     Step 3 — reset the password so it is stored with the current method" >&2
            echo "     (you will be prompted):" >&2
            _pg_admin_cmd "psql -c '\\password $pg_user'" >&2
        elif echo "$psql_out" | grep -qi "peer authentication failed\|ident authentication failed"; then
            if [ "$is_socket" = "true" ]; then
                echo "  ✘  pg_hba.conf does not allow password auth for Unix socket connections." >&2
                echo "     Edit pg_hba.conf and add or update the 'local' entry for '${pg_db}'" >&2
                echo "     and '${pg_user}' to use 'scram-sha-256' or 'md5':" >&2
                echo "       local   ${pg_db}   ${pg_user}   scram-sha-256" >&2
            else
                echo "  ✘  pg_hba.conf does not allow password auth for local TCP connections." >&2
                echo "     Edit pg_hba.conf and set the method to 'scram-sha-256' or 'md5'" >&2
                echo "     for host connections to '${pg_db}' by '${pg_user}':" >&2
                echo "       host   ${pg_db}   ${pg_user}   127.0.0.1/32   scram-sha-256" >&2
            fi >&2
            echo "     To find pg_hba.conf:" >&2
            _pg_admin_cmd "psql -c 'SHOW hba_file;'" >&2
            echo "     Then reload:" >&2
            _pg_admin_cmd "psql -c 'SELECT pg_reload_conf();'" >&2
        else
            echo "  ✘  Connection failed: $(echo "$psql_out" | grep -i "fatal\|error" | head -1)" >&2
        fi
        return 1
}

# Warn if a DATABASE_URL uses localhost/127.0.0.1 — those resolve to the
# container itself inside Docker, not the host machine.
warn_if_localhost_url() {
    local url="$1"
    if [[ "$url" == *"@localhost:"* ]] || [[ "$url" == *"@127.0.0.1:"* ]]; then
        echo "" >&2
        echo "  ⚠  The DATABASE_URL uses 'localhost', which inside Docker resolves to" >&2
        echo "     the container itself — not this host machine." >&2
        echo "     Use 'host.docker.internal' instead of 'localhost' to reach a" >&2
        echo "     database running on this host." >&2
        echo "" >&2
    fi
}

# Wait until PostgreSQL on the given host is accepting connections.
# Uses pg_isready when available; falls back to a bash TCP probe otherwise.
# Always validates — never silently passes.
wait_for_postgres_ready() {
    local host="${1:-localhost}"
    local port="${2:-5432}"
    echo "" >&2
    echo "  Checking that PostgreSQL is accepting connections..." >&2
    if command -v pg_isready >/dev/null 2>&1; then
        while ! pg_isready -h "$host" -p "$port" -t 1 >/dev/null 2>&1; do
            echo "  ⚠  Not ready yet. Press Enter to retry (Ctrl+C to abort)." >&2
            read -r _
        done
    else
        # pg_isready not available — use bash's built-in /dev/tcp to probe the port
        # shellcheck disable=SC2188
        while ! (>/dev/tcp/"$host"/"$port") 2>/dev/null; do
            echo "  ⚠  Not ready yet. Press Enter to retry (Ctrl+C to abort)." >&2
            read -r _
        done
    fi
    echo "  ✔  PostgreSQL is accepting connections at $host." >&2
    echo "" >&2
}

# Print platform-specific instructions for installing PostgreSQL locally.
# All output goes to stderr so this function is safe inside $() subshells.
# Note: Linux commands use 'sudo su - postgres' (login shell) so the postgres
# user starts in its own home directory, avoiding cwd permission errors.
show_local_postgres_install_instructions() {
    local os; os="$(uname -s)"
    echo "" >&2
    echo "  ── Install PostgreSQL locally ────────────────────────────────────────" >&2
    echo "  PostgreSQL 14 or later is required (Django 5.x minimum)." >&2
    echo "  Run the following commands to install a supported version:" >&2
    echo "" >&2
    if [[ "$os" == "Darwin" ]]; then
        echo "    brew install postgresql@17" >&2
        echo "    brew services start postgresql@17" >&2
        echo "    createuser -s -P mytracks   # -P prompts for password interactively" >&2
        echo "    createdb -O mytracks mytracks" >&2
    elif command -v apt-get >/dev/null 2>&1; then
        # Use PGDG repo to guarantee a supported version (distro default may be < 14)
        echo "    sudo apt-get install -y curl ca-certificates" >&2
        echo "    sudo install -d /usr/share/postgresql-common/pgdg" >&2
        echo "    sudo curl -o /usr/share/postgresql-common/pgdg/apt.postgresql.org.asc --fail \\" >&2
        echo "        https://www.postgresql.org/media/keys/ACCC4CF8.asc" >&2
        echo "    sudo sh -c 'echo \"deb [signed-by=/usr/share/postgresql-common/pgdg/apt.postgresql.org.asc] \\" >&2
        echo "        https://apt.postgresql.org/pub/repos/apt \$(lsb_release -cs)-pgdg main\" \\" >&2
        echo "        > /etc/apt/sources.list.d/pgdg.list'" >&2
        echo "    sudo apt-get update && sudo apt-get install -y postgresql-17" >&2
        echo "    sudo systemctl enable --now postgresql@17-main" >&2
        echo "    sudo su - postgres -c \"createuser -s -P mytracks\"" >&2
        echo "    sudo su - postgres -c \"createdb -O mytracks mytracks\"" >&2
    elif command -v dnf >/dev/null 2>&1; then
        # Use PGDG repo — distro default on RHEL 8/9 is PG 10-13 (unsupported)
        echo "    sudo dnf install -y https://download.postgresql.org/pub/repos/yum/reporpms/EL-8-x86_64/pgdg-redhat-repo-latest.noarch.rpm" >&2
        echo "    sudo dnf -qy module disable postgresql" >&2
        echo "    sudo dnf install -y postgresql17-server" >&2
        echo "    sudo /usr/pgsql-17/bin/postgresql-17-setup initdb" >&2
        echo "    sudo systemctl enable --now postgresql-17" >&2
        echo "    sudo su - postgres -c \"createuser -s -P mytracks\"" >&2
        echo "    sudo su - postgres -c \"createdb -O mytracks mytracks\"" >&2
    elif command -v pacman >/dev/null 2>&1; then
        # Arch official repos always carry the latest version (currently 16+)
        echo "    sudo pacman -S postgresql" >&2
        echo "    sudo -u postgres initdb -D /var/lib/postgres/data" >&2
        echo "    sudo systemctl enable --now postgresql" >&2
        echo "    sudo su - postgres -c \"createuser -s -P mytracks\"" >&2
        echo "    sudo su - postgres -c \"createdb -O mytracks mytracks\"" >&2
    else
        echo "    Install PostgreSQL 14 or later using your system's package manager." >&2
        echo "    Official packages: https://www.postgresql.org/download/" >&2
        echo "    Then start the service and create the user and database:" >&2
        echo "      sudo su - postgres -c \"createuser -s -P mytracks\"" >&2
        echo "      sudo su - postgres -c \"createdb -O mytracks mytracks\"" >&2
    fi
    echo "" >&2
}

# Prompt for a raw DATABASE_URL and probe it; retries on failure.
# Outputs the validated URL to stdout; all interaction goes to stderr.
prompt_db_url() {
    local db_url
    echo "" >&2
    printf "  DATABASE_URL (e.g., postgresql://user:pass@host:5432/dbname): " >&2
    read -r db_url
    [ -n "$db_url" ] || die "DATABASE_URL cannot be empty"

    while ! probe_db_connection "$db_url"; do
        echo "" >&2
        printf "  Press Enter to retry, or type 'edit' to enter a different URL (Ctrl+C to abort): " >&2
        local retry_input
        read -r retry_input
        if [ "$retry_input" = "edit" ]; then
            printf "  DATABASE_URL: " >&2
            local new_url
            read -r new_url
            [ -n "$new_url" ] && db_url="$new_url"
        fi
    done

    warn_if_localhost_url "$db_url"
    echo "$db_url"
}

# Gather individual connection fields for a local postgres and build a DATABASE_URL.
# Probes connectivity; retries on failure.
# Outputs the validated URL to stdout; all interaction goes to stderr.
# The user enters a normal hostname (default: localhost). After a successful probe
# the URL is rewritten to use host.docker.internal so it resolves from inside the
# containers on both Linux (via extra_hosts) and Docker Desktop (macOS).
prompt_local_db_url() {
    local host port dbname user password db_url enc_user enc_password
    local h p d u
    echo "" >&2
    echo "  ── PostgreSQL connection details ──" >&2
    echo "  (Press Enter to accept the default shown in brackets)" >&2
    printf "  Host [localhost]: " >&2; read -r host; host="${host:-localhost}"
    printf "  Port [5432]: " >&2; read -r port; port="${port:-5432}"
    printf "  Database name [mytracks]: " >&2; read -r dbname; dbname="${dbname:-mytracks}"
    printf "  Username [mytracks]: " >&2; read -r user; user="${user:-mytracks}"
    printf "  Password: " >&2; IFS= read -rs password; echo "" >&2
    [ -n "$password" ] || die "Password cannot be empty"
    enc_user="$(urlencode "$user")"
    enc_password="$(urlencode "$password")"
    db_url="postgresql://${enc_user}:${enc_password}@${host}:${port}/${dbname}"

    while ! probe_db_connection "$db_url"; do
        echo "" >&2
        printf "  Press Enter to retry, or type 'edit' to change connection settings (Ctrl+C to abort): " >&2
        local retry_input
        read -r retry_input
        if [ "$retry_input" = "edit" ]; then
            printf "  Host [%s]: " "$host" >&2; read -r h; host="${h:-$host}"
            printf "  Port [%s]: " "$port" >&2; read -r p; port="${p:-$port}"
            printf "  Database name [%s]: " "$dbname" >&2; read -r d; dbname="${d:-$dbname}"
            printf "  Username [%s]: " "$user" >&2; read -r u; user="${u:-$user}"
            printf "  Password [keep current]: " >&2; IFS= read -rs new_password; echo "" >&2
            [ -n "$new_password" ] && password="$new_password"
            enc_user="$(urlencode "$user")"
            enc_password="$(urlencode "$password")"
            db_url="postgresql://${enc_user}:${enc_password}@${host}:${port}/${dbname}"
        fi
    done

    # Rewrite localhost/127.0.0.1 → host.docker.internal so the URL resolves
    # from inside Docker containers (which can't reach the host via localhost).
    db_url="${db_url/@localhost:/@host.docker.internal:}"
    db_url="${db_url/@127.0.0.1:/@host.docker.internal:}"

    warn_if_localhost_url "$db_url"
    echo "$db_url"
}

# Gather connection details for a local Unix-socket PostgreSQL and build a DATABASE_URL.
# $1: host-side socket directory (e.g. /var/run/postgresql).
# Probes using the host socket path; the stored URL uses the container mount point
# /var/run/postgresql (docker-compose.socket.yml mounts host dir there).
# Outputs the validated URL followed by "SOCKET_DIR:<host_socket_dir>" on the next
# line so callers can extract the host path without a global side-channel.
# All interaction goes to stderr.
prompt_socket_db_url() {
    local host_socket_dir="$1"
    local dbname user password enc_user enc_password db_url
    local d u
    echo "" >&2
    echo "  ── PostgreSQL Unix socket connection ──" >&2
    echo "  (Press Enter to accept the default shown in brackets)" >&2
    printf "  Database name [mytracks]: " >&2; read -r dbname; dbname="${dbname:-mytracks}"
    printf "  Username [mytracks]: " >&2; read -r user; user="${user:-mytracks}"
    printf "  Password: " >&2; IFS= read -rs password; echo "" >&2
    [ -n "$password" ] || die "Password cannot be empty"
    enc_user="$(urlencode "$user")"
    enc_password="$(urlencode "$password")"
    # Container-side socket path is always /var/run/postgresql (mounted from host).
    db_url="postgresql://${enc_user}:${enc_password}@/${dbname}?host=/var/run/postgresql"

    while ! probe_db_connection "$db_url" "$host_socket_dir"; do
        echo "" >&2
        printf "  Press Enter to retry, or type 'edit' to change settings (Ctrl+C to abort): " >&2
        local retry_input
        read -r retry_input
        if [ "$retry_input" = "edit" ]; then
            printf "  Database name [%s]: " "$dbname" >&2; read -r d; dbname="${d:-$dbname}"
            printf "  Username [%s]: " "$user" >&2; read -r u; user="${u:-$user}"
            printf "  Password [keep current]: " >&2; IFS= read -rs new_password; echo "" >&2
            [ -n "$new_password" ] && password="$new_password"
            enc_user="$(urlencode "$user")"
            enc_password="$(urlencode "$password")"
            db_url="postgresql://${enc_user}:${enc_password}@/${dbname}?host=/var/run/postgresql"
        fi
    done

    echo "$db_url"
    echo "SOCKET_DIR:${host_socket_dir}"
}

# Guide the user through configuring an external PostgreSQL connection.
# Detects a locally-running postgres and offers to use it.
# Outputs the validated DATABASE_URL to stdout; all interaction goes to stderr.
setup_external_database() {
    local use_local="false"

    # Detect a locally-running postgres (only possible when pg_isready is available)
    if command -v pg_isready >/dev/null 2>&1; then
        if pg_isready -h localhost -t 1 >/dev/null 2>&1; then
            if ! _early_pg_version_check; then
                echo "  ⚠  Skipping local PostgreSQL — upgrade first, then re-run." >&2
                echo "" >&2
            else
                echo "" >&2
                echo "  ✔  Local PostgreSQL detected at localhost." >&2
                printf "  Use it? [Y/n] (Enter=Y): " >&2
                local local_choice
                read -r local_choice
                local_choice="${local_choice:-y}"
                if [[ "$local_choice" =~ ^[Yy] ]]; then
                    use_local="true"
                fi
            fi
        fi
    fi

    if [ "$use_local" = "true" ]; then
        # Offer Unix socket if one is available — avoids exposing postgres on the network.
        local sock_dir
        if sock_dir="$(detect_pg_socket_dir)"; then
            echo "" >&2
            echo "  ✔  Unix socket found at: $sock_dir" >&2
            echo "     Using a socket avoids exposing PostgreSQL on the network." >&2
            printf "  Connect via Unix socket? [Y/n] (Enter=Y): " >&2
            local sock_choice
            read -r sock_choice
            sock_choice="${sock_choice:-y}"
            if [[ "$sock_choice" =~ ^[Yy] ]]; then
                prompt_socket_db_url "$sock_dir"
                return
            fi
        fi
        prompt_local_db_url
        return
    fi

    echo "" >&2
    echo "  ── No local PostgreSQL server detected ──" >&2
    echo "    a) Install and run PostgreSQL on this machine" >&2
    echo "    b) Connect to a remote PostgreSQL server" >&2
    echo "" >&2
    printf "  Choose [a (default)]: " >&2
    local pg_choice
    read -r pg_choice
    pg_choice="${pg_choice:-a}"

    if [ "$pg_choice" = "a" ]; then
        show_local_postgres_install_instructions
        while true; do
            printf "  Press Enter when done (Ctrl+C to abort)..." >&2
            read -r _
            wait_for_postgres_ready localhost
            _early_pg_version_check && break
            echo "" >&2
            echo "  Fix the PostgreSQL version and try again, or press Ctrl+C to abort." >&2
            echo "" >&2
        done
        prompt_local_db_url
    else
        prompt_db_url
    fi
}

# Inform user of internal DB or probe external DB for connectivity.
# Takes the DATABASE_URL as an argument so there is no implicit global dependency.
# When the URL targets host.docker.internal, also verifies that postgres is
# listening on an address the container can actually reach (not just localhost).
# If it isn't, offers to migrate the env file to use a Unix socket.
verify_database_connectivity() {
    local url="$1"
    if is_internal_db; then
        echo ""
        echo "  ℹ  Database: containerized PostgreSQL (transient; data in Docker volume)"
        echo ""
        return
    fi

    echo ""
    echo "  ── Verifying external database ──────────────────────────────"
    if probe_db_connection "$url"; then
        echo "  ✔  External database is reachable."
        warn_if_localhost_url "$url"
        # The probe above substitutes host.docker.internal → localhost, so it
        # succeeds even when postgres is not listening on the host's LAN IP.
        # Verify containers can actually reach it; offer socket migration if not.
        if [[ "$url" == *"host.docker.internal"* ]]; then
            _check_container_reachability "$url"
        fi
        echo ""
    else
        die "Cannot reach external database: $(mask_password_in_url "$url")

  Ensure the database server is running and accessible from this host.
  Verify DATABASE_URL in $env_file."
    fi
}

# Called when DATABASE_URL uses host.docker.internal.
# Queries postgres listen_addresses to determine whether the host's LAN interface
# is actually exposed. If postgres only listens on localhost, the container will
# fail to connect via host.docker.internal (which resolves to the LAN IP).
# Offers to migrate the env file to use a Unix socket if one is available.
# Falls back silently (best-effort) when psql is unavailable or query fails.
_check_container_reachability() {
    local url="$1"
    command -v psql >/dev/null 2>&1 || return 0

    local probe_url="${url/host.docker.internal/localhost}"
    local pg_user pg_password pg_db probe_port
    parse_db_url "$probe_url"
    pg_user="$_db_user"
    pg_password="$_db_password"
    pg_db="$_db_name"
    probe_port="$_db_port"

    local listen_addrs
    listen_addrs="$(_run_psql "$pg_password" \
        -h localhost -p "$probe_port" -U "$pg_user" -d "$pg_db" \
        -t -c 'SHOW listen_addresses;' 2>/dev/null | tr -d ' \n')"

    # Empty means psql failed — skip silently (best-effort).
    [ -n "$listen_addrs" ] || return 0

    # If listen_addresses includes '*', '0.0.0.0', or a non-loopback IP, the
    # container can reach postgres. Only block when it is strictly loopback-only.
    if [[ "$listen_addrs" != "localhost" && "$listen_addrs" != "127.0.0.1" && \
          "$listen_addrs" != "::1" ]]; then
        return 0
    fi

    echo "" >&2
    echo "  ⚠  PostgreSQL listen_addresses='${listen_addrs}' — it only accepts" >&2
    echo "     loopback connections. Docker containers cannot reach it via" >&2
    echo "     host.docker.internal (which resolves to the host's LAN IP)." >&2

    local sock_dir
    if sock_dir="$(detect_pg_socket_dir)"; then
        echo "  ✔  Unix socket found at: $sock_dir" >&2
        printf "  Migrate DATABASE_URL to Unix socket (recommended)? [Y/n] (Enter=Y): " >&2
        local choice
        read -r choice
        choice="${choice:-y}"
        if [[ "$choice" =~ ^[Yy] ]]; then
            _migrate_env_to_socket "$pg_user" "$pg_password" "$pg_db" "$sock_dir"
            return 0
        fi
    fi

    echo "" >&2
    echo "  To allow container access without a socket, configure PostgreSQL:" >&2
    _pg_admin_cmd "psql -c \"ALTER SYSTEM SET listen_addresses = '*'; SELECT pg_reload_conf();\"" >&2
    echo "  Also add a host entry in pg_hba.conf for the Docker subnet." >&2
    die "PostgreSQL is not reachable from Docker containers via host.docker.internal."
}

# Rewrites DATABASE_URL in .env.production to use a Unix socket and adds
# PG_SOCKET_DIR, then reloads config and compose file list.
_migrate_env_to_socket() {
    local pg_user="$1" pg_password="$2" pg_db="$3" sock_dir="$4"
    local enc_user enc_password new_url
    enc_user="$(urlencode "$pg_user")"
    enc_password="$(urlencode "$pg_password")"
    new_url="postgresql://${enc_user}:${enc_password}@/${pg_db}?host=/var/run/postgresql"

    # Rewrite env file atomically: strip old DATABASE_URL / PG_SOCKET_DIR, append new.
    local tmp_file
    tmp_file="$(mktemp)"
    grep -v "^DATABASE_URL=" "$env_file" | grep -v "^PG_SOCKET_DIR=" > "$tmp_file"
    {
        echo "DATABASE_URL=${new_url}"
        echo "PG_SOCKET_DIR=${sock_dir}"
    } >> "$tmp_file"
    mv "$tmp_file" "$env_file"
    chmod 600 "$env_file"

    # Reload config and compose file list so the rest of cmd_start uses the
    # updated values (socket overlay will be included, database_url refreshed).
    load_config_from_env
    setup_compose_files
    info "Migrated to Unix socket. Updated DATABASE_URL and PG_SOCKET_DIR in $env_file."
}

usage() {
    cat <<EOF
Usage: my-tracks-production-container-manager [OPTIONS]

Options:
  --start                Build and start the production container stack
  --freshen-up           Tear down stack, delete config/certs, and prompt before each deletion
  --start --freshen-up   Tear down, wipe config/certs, then reconfigure and start immediately
  --start --import-sqlite [path]
                         Import local SQLite db into PostgreSQL (default: ./db.sqlite3)
  --stop                 Stop the stack and remove volumes
  -h, --help             Show this help message

Default ports (chosen to avoid conflicts with dev server):
  HTTPS:    ${default_https_port}  →  https://localhost:${default_https_port}
  HTTP:     ${default_http_port}  →  redirects to HTTPS
  MQTT TLS: ${default_mqtt_tls_port}

Database:
  By default, a containerized PostgreSQL is started (transient, data in Docker volume).
  To use an external PostgreSQL, set DATABASE_URL in .env.production and omit
  POSTGRES_USER/POSTGRES_PASSWORD/POSTGRES_DB.
EOF
}

# ── Environment & Certs ─────────────────────────────────────────────────────

readonly env_spec=(
    "SECRET_KEY|auto|Django secret key"
    "DEBUG|False|Debug mode"
    "ALLOWED_HOSTS|localhost,127.0.0.1|Allowed hostnames"
    "CSRF_TRUSTED_ORIGINS|https://localhost:${default_https_port}|Trusted CSRF origins"
    "HTTPS_PORT|${default_https_port}|Host HTTPS port"
    "HTTP_PORT|${default_http_port}|Host HTTP port"
    "MQTT_TLS_PORT|${default_mqtt_tls_port}|Host MQTT TLS port"
)

readonly internal_db_spec=(
    "POSTGRES_USER|mytracks|PostgreSQL username"
    "POSTGRES_PASSWORD|auto|PostgreSQL password"
    "POSTGRES_DB|mytracks|PostgreSQL database name"
)

prompt_value() {
    local var_name="$1" default="$2" description="$3"
    local current value

    current="$(env_get "$var_name")"
    if [ -n "$current" ]; then
        echo "$current"
        return
    fi

    if [ "$default" = "auto" ]; then
        generate_secret
        return
    fi

    printf "  %s (%s) [%s]: " "$var_name" "$description" "$default" >&2
    read -r value
    echo "${value:-$default}"
}

choose_containerized_postgres_mode() {
    local data_dir="$prod_dir/var/db"
    echo "" >&2
    echo "  ── Containerized PostgreSQL ──" >&2
    echo "    a) Transient   — data in a Docker volume; wiped on --stop  [testing/ephemeral use]" >&2
    echo "    b) Persistent  — data on host at $data_dir" >&2
    echo "                     (survives --stop and container restarts)" >&2
    echo "" >&2
    printf "  Choose [a (default)]: " >&2
    local sub_choice
    read -r sub_choice
    sub_choice="${sub_choice:-a}"

    if [ "$sub_choice" = "b" ]; then
        echo "internal-persistent"
    else
        echo "internal-transient"
    fi
}

choose_database_mode() {
    echo "" >&2
    echo "  ── Database configuration ──" >&2
    echo "    1) Containerized PostgreSQL (PostgreSQL runs inside the stack)" >&2
    echo "    2) External PostgreSQL (connect to an existing PostgreSQL server)" >&2
    echo "" >&2
    printf "  Choose [1 (default)]: " >&2
    local db_choice
    read -r db_choice
    db_choice="${db_choice:-1}"

    if [ "$db_choice" = "2" ]; then
        local db_url
        db_url="$(setup_external_database)" || exit 1
        echo "$db_url"
    else
        choose_containerized_postgres_mode
    fi
}

extract_source_env_value() {
    local var_name="$1"
    grep -E "^${var_name}=" "$project_dir/.env" 2>/dev/null | head -1 | cut -d= -f2-
}

extract_source_secret_key() {
    # Resolve the SECRET_KEY that Django actually uses (what decouple.config()
    # returns), which accounts for env vars, .env, and settings.py defaults.
    # Falls back to reading .env directly if Django resolution fails.
    # Prints the key to stdout; prints the source location to stderr.
    local key

    key="$(DJANGO_SETTINGS_MODULE=config.settings \
        DATABASE_URL="sqlite:///dev-null" \
        uv run --directory "$project_dir" python -c \
            "from django.conf import settings; print(settings.SECRET_KEY)" 2>/dev/null || true)"
    if [ -n "$key" ]; then
        info "Found SECRET_KEY via Django settings (resolves .env + defaults)"
        echo "$key"
        return
    fi

    key="$(extract_source_env_value "SECRET_KEY")"
    if [ -n "$key" ]; then
        info "Found SECRET_KEY in $project_dir/.env"
        echo "$key"
        return
    fi
}

build_csrf_origins() {
    local allowed_hosts="$1" https_port="$2"
    local origins=""
    IFS=',' read -ra hosts <<< "$allowed_hosts"
    for host in "${hosts[@]}"; do
        host="$(echo "$host" | xargs)"
        [ -z "$host" ] && continue
        if [ -n "$origins" ]; then
            origins="${origins},"
        fi
        if [ "$https_port" = "443" ]; then
            origins="${origins}https://${host}"
        else
            origins="${origins}https://${host}:${https_port}"
        fi
    done
    echo "$origins"
}

create_env_file() {
    local override_allowed_hosts="${1:-}"

    info "Generating .env.production"

    local raw_db_result db_result
    raw_db_result="$(choose_database_mode)" || die "Database setup failed — aborting."
    _pg_socket_dir="$(echo "$raw_db_result" | grep '^SOCKET_DIR:' | sed 's/^SOCKET_DIR://' || true)"
    db_result="$(echo "$raw_db_result" | grep -v '^SOCKET_DIR:')"

    local secret_key
    secret_key="$(generate_secret)"

    local allowed_hosts
    if [ -n "$override_allowed_hosts" ]; then
        allowed_hosts="$override_allowed_hosts"
        info "Using ALLOWED_HOSTS from source environment: $allowed_hosts"
    else
        allowed_hosts="localhost,127.0.0.1"
    fi

    local csrf_origins
    csrf_origins="$(build_csrf_origins "$allowed_hosts" "$default_https_port")"

    if [ "$db_result" = "internal-transient" ] || [ "$db_result" = "internal-persistent" ]; then
        local pg_password enc_pg_password
        pg_password="$(generate_secret)"
        enc_pg_password="$(urlencode "$pg_password")"

        cat > "$env_file" <<ENVEOF
SECRET_KEY=${secret_key}
DEBUG=False
ALLOWED_HOSTS=${allowed_hosts}
CSRF_TRUSTED_ORIGINS=${csrf_origins}
POSTGRES_USER=mytracks
POSTGRES_PASSWORD=${pg_password}
POSTGRES_DB=mytracks
DATABASE_URL=postgresql://mytracks:${enc_pg_password}@postgres:5432/mytracks
HTTPS_PORT=${default_https_port}
HTTP_PORT=${default_http_port}
MQTT_TLS_PORT=${default_mqtt_tls_port}
ENVEOF
        if [ "$db_result" = "internal-persistent" ]; then
            local data_dir="$prod_dir/var/db"
            {
                echo "POSTGRES_MODE=persistent"
                echo "POSTGRES_DATA_DIR=${data_dir}"
            } >> "$env_file"
        else
            echo "POSTGRES_MODE=transient" >> "$env_file"
        fi
    else
        cat > "$env_file" <<ENVEOF
SECRET_KEY=${secret_key}
DEBUG=False
ALLOWED_HOSTS=${allowed_hosts}
CSRF_TRUSTED_ORIGINS=${csrf_origins}
DATABASE_URL=${db_result}
HTTPS_PORT=${default_https_port}
HTTP_PORT=${default_http_port}
MQTT_TLS_PORT=${default_mqtt_tls_port}
ENVEOF
        if [ -n "$_pg_socket_dir" ]; then
            echo "PG_SOCKET_DIR=${_pg_socket_dir}" >> "$env_file"
        fi
    fi

    chmod 600 "$env_file"
    info "Created $env_file"
}

validate_and_repair_env() {
    local missing=() var_name default description
    for spec in "${env_spec[@]}"; do
        IFS='|' read -r var_name default description <<< "$spec"
        if [ -z "$(env_get "$var_name")" ]; then
            missing+=("$spec")
        fi
    done

    if [ -z "$(env_get "DATABASE_URL")" ]; then
        local raw_db_result db_result
        raw_db_result="$(choose_database_mode)"
        _pg_socket_dir="$(echo "$raw_db_result" | grep '^SOCKET_DIR:' | sed 's/^SOCKET_DIR://' || true)"
        db_result="$(echo "$raw_db_result" | grep -v '^SOCKET_DIR:')"
        if [ "$db_result" = "internal-transient" ] || [ "$db_result" = "internal-persistent" ]; then
            local pg_password enc_pg_password
            pg_password="$(generate_secret)"
            enc_pg_password="$(urlencode "$pg_password")"
            {
                echo "POSTGRES_USER=mytracks"
                echo "POSTGRES_PASSWORD=${pg_password}"
                echo "POSTGRES_DB=mytracks"
                echo "DATABASE_URL=postgresql://mytracks:${enc_pg_password}@postgres:5432/mytracks"
            } >> "$env_file"
            if [ "$db_result" = "internal-persistent" ]; then
                local data_dir="$prod_dir/var/db"
                {
                    echo "POSTGRES_MODE=persistent"
                    echo "POSTGRES_DATA_DIR=${data_dir}"
                } >> "$env_file"
            else
                echo "POSTGRES_MODE=transient" >> "$env_file"
            fi
            info "Added internal database configuration to $env_file"
        else
            echo "DATABASE_URL=${db_result}" >> "$env_file"
            if [ -n "$_pg_socket_dir" ]; then
                echo "PG_SOCKET_DIR=${_pg_socket_dir}" >> "$env_file"
            fi
            info "Added external DATABASE_URL to $env_file"
        fi
    fi

    if is_internal_db; then
        for spec in "${internal_db_spec[@]}"; do
            IFS='|' read -r var_name default description <<< "$spec"
            if [ -z "$(env_get "$var_name")" ]; then
                missing+=("$spec")
            fi
        done
    fi

    if [ ${#missing[@]} -eq 0 ]; then
        return
    fi

    echo ""
    info "Missing variables in $env_file — filling in:"
    echo ""

    for spec in "${missing[@]}"; do
        IFS='|' read -r var_name default description <<< "$spec"
        local value
        value="$(prompt_value "$var_name" "$default" "$description")"
        echo "${var_name}=${value}" >> "$env_file"
    done

    echo ""
    info "Updated $env_file with missing values"
    chmod 600 "$env_file"
}

load_config_from_env() {
    active_https_port="$(env_get "HTTPS_PORT")"
    active_https_port="${active_https_port:-$default_https_port}"
    active_http_port="$(env_get "HTTP_PORT")"
    active_http_port="${active_http_port:-$default_http_port}"
    active_mqtt_tls_port="$(env_get "MQTT_TLS_PORT")"
    active_mqtt_tls_port="${active_mqtt_tls_port:-$default_mqtt_tls_port}"
    health_url="https://localhost:${active_https_port}/api/health/"

    db_user="$(env_get "POSTGRES_USER")"
    db_user="${db_user:-mytracks}"
    db_name="$(env_get "POSTGRES_DB")"
    db_name="${db_name:-mytracks}"
    database_url="$(env_get "DATABASE_URL")"
}

import_sqlite_to_postgres() {
    local sqlite_path="$1"
    local old_secret_key="${2:-}"

    if [ ! -f "$sqlite_path" ]; then
        die "SQLite database not found: $sqlite_path"
    fi

    info "Importing SQLite database: $sqlite_path"

    info "Dumping data from SQLite (via Django dumpdata)..."
    local dump_file
    dump_file="$(mktemp "${TMPDIR:-/tmp}/my-tracks-dump-XXXXXX").json"

    DJANGO_SETTINGS_MODULE=config.settings \
        DATABASE_URL="sqlite:///$sqlite_path" \
        uv run --directory "$project_dir" python manage.py dumpdata \
            --natural-foreign --natural-primary \
            --exclude contenttypes --exclude auth.permission \
            --exclude admin.logentry --exclude sessions \
            --exclude my_tracks.userprofile \
            --indent 2 \
            -o "$dump_file" 2>&1 || die "Failed to dump SQLite data"

    local record_count
    record_count="$(awk '/^  \{/{n++} END{print n+0}' "$dump_file" 2>/dev/null || echo "unknown")"
    info "Exported $record_count records from SQLite"

    info "Loading data into PostgreSQL (via Django loaddata)..."
    compose run --rm --entrypoint "" -T my-tracks \
        python manage.py loaddata --format json - < "$dump_file" \
        || die "Failed to import data into PostgreSQL"

    rm -f "$dump_file"
    info "Successfully imported $record_count records into PostgreSQL"

    if [ -n "$old_secret_key" ]; then
        info "Re-encrypting PKI private keys with the new production SECRET_KEY..."
        local reencrypt_ok="false"

        if compose run --rm --entrypoint "" -T my-tracks \
            python manage.py reencrypt_pki --old-secret-key "$old_secret_key" 2>&1; then
            reencrypt_ok="true"
        else
            echo ""
            echo "  ⚠  Primary key didn't work. Trying Django's default insecure key..."
            local fallback_key="django-insecure-change-me-in-production"
            if compose run --rm --entrypoint "" -T my-tracks \
                python manage.py reencrypt_pki --old-secret-key "$fallback_key" 2>&1; then
                reencrypt_ok="true"
            fi
        fi

        if [ "$reencrypt_ok" = "true" ]; then
            echo ""
            echo "  ✔ PKI private keys re-encrypted with the new production SECRET_KEY."
            echo "    CA, server, and client certificate keys are now secured with"
            echo "    the strong key in $env_file."
            echo ""
        else
            echo ""
            echo "  ✘ Could not re-encrypt PKI keys — neither the extracted key nor"
            echo "    the Django default matched. PKI certificates will need new keys."
            echo ""
            echo "    To fix manually after the stack is running:"
            echo "      1. Find the original SECRET_KEY"
            echo "      2. Run: $compose_cmd --env-file $env_file exec my-tracks \\"
            echo "           python manage.py reencrypt_pki --old-secret-key YOUR_OLD_KEY"
            echo ""
        fi
    fi
}

create_self_signed_certs() {
    info "Generating self-signed TLS certificates"
    mkdir -p "$CERTS_DIR"
    openssl req -x509 -nodes -days 365 -newkey rsa:2048 \
        -keyout "$CERTS_DIR/privkey.pem" \
        -out "$CERTS_DIR/fullchain.pem" \
        -subj "/CN=localhost" \
        2>/dev/null
    info "Certs written to $CERTS_DIR/"
}

# ── Banner ───────────────────────────────────────────────────────────────────

print_banner() {
    local compose_manual="$compose_cmd --env-file $env_file"
    local compose_files_display=""
    for f in "${compose_files[@]}"; do
        compose_files_display="$compose_files_display $f"
    done

    local health_response
    health_response="$(curl -sk "$health_url" 2>/dev/null)"

    echo ""
    echo "╔══════════════════════════════════════════════════════════════╗"
    echo "║              my-tracks production stack running             ║"
    echo "╚══════════════════════════════════════════════════════════════╝"
    echo ""
    echo "  Health:    $health_response"
    echo "  Web UI:    https://localhost:${active_https_port}"
    echo "  API:       https://localhost:${active_https_port}/api/"
    echo "  MQTT TLS:  0.0.0.0:${active_mqtt_tls_port}  (all interfaces)"
    echo ""

    if is_internal_db; then
        print_internal_db_banner "$compose_manual"
    else
        print_external_db_banner
    fi

    echo "  ── Local files ───────────────────────────────────────────"
    echo "  Nginx config:  $prod_dir/run/nginx/"
    echo "  TLS certs:     $prod_dir/run/certs/"
    echo "  App logs:      $prod_dir/var/log/"
    echo ""
    echo "  ── Commands ──────────────────────────────────────────────"
    echo "  Create admin user:"
    echo "    $compose_manual${compose_files_display} exec my-tracks python manage.py createsuperuser"
    echo ""
    echo "  View container logs:"
    echo "    $compose_manual${compose_files_display} logs -f my-tracks"
    echo ""
    echo "  Tail application log:"
    echo "    tail -f $prod_dir/var/log/my-tracks.log"
    echo ""
    echo "  Stop (destroys volumes):"
    echo "    $script_dir/my-tracks-production-container-manager --stop"
    echo ""
    echo "  Stop (preserves data):"
    echo "    $compose_manual${compose_files_display} down"
    echo ""
}

print_internal_db_banner() {
    local compose_manual="$1"
    local compose_files_display=""
    for f in "${compose_files[@]}"; do
        compose_files_display="$compose_files_display $f"
    done

    echo "  ── Database (containerized) ────────────────────────────────"
    echo "  Engine:    PostgreSQL 17 (container: postgres)"
    echo "  Host:      localhost (internal to Docker network)"
    echo "  Database:  ${db_name}"
    echo "  User:      ${db_user}"
    echo ""
    echo "  ⚠  DATABASE IS TRANSIENT: Data lives in a Docker volume."
    echo "     Running --stop destroys the volume and ALL data."
    echo "     To preserve data between restarts:"
    echo "       $compose_manual${compose_files_display} down  (without -v)"
    echo ""
    echo "  Browse data:"
    echo "    $compose_manual${compose_files_display} exec postgres psql -U ${db_user} ${db_name}"
    echo ""
    echo "     For persistent storage, use an external PostgreSQL instead:"
    echo "       1. Set DATABASE_URL in .env.production"
    echo "          (e.g., postgresql://user:pass@your-db-host:5432/mytracks)"
    echo "       2. Remove POSTGRES_USER, POSTGRES_PASSWORD, POSTGRES_DB entries"
    echo "       3. Restart with --freshen-up"
    echo "     The containerized postgres will not be started when DATABASE_URL"
    echo "     points to an external host."
    echo ""
}

print_external_db_banner() {
    local masked_url
    masked_url="$(mask_password_in_url "$database_url")"

    echo "  ── Database (external) ─────────────────────────────────────"
    echo "  URL:       $masked_url"
    echo ""
    echo "  ℹ  Database is managed externally — not affected by --stop."
    echo ""
}

stage_bind_mounts() {
    # Stage nginx config and certs into run/ for Docker bind-mount access.
    # Colima shares ~/ via virtiofs, so run/ must be inside the repo to be
    # reachable from both the macOS host and the Docker VM.
    # Logs go directly to var/log/ (persistent) — not staged here.
    local run_dir="$prod_dir/run"
    mkdir -p "$run_dir/nginx" "$run_dir/certs"

    cp "$project_dir/nginx/nginx.conf" "$run_dir/nginx/nginx.conf"
    cp "$project_dir/nginx/proxy_params" "$run_dir/nginx/proxy_params"
    cp "$CERTS_DIR/fullchain.pem" "$run_dir/certs/fullchain.pem"
    cp "$CERTS_DIR/privkey.pem" "$run_dir/certs/privkey.pem"

    chmod a+rX "$run_dir" \
               "$run_dir/nginx" "$run_dir/nginx/nginx.conf" "$run_dir/nginx/proxy_params" \
               "$run_dir/certs" "$run_dir/certs/fullchain.pem" "$run_dir/certs/privkey.pem"

    export NGINX_CONF_DIR="$run_dir/nginx"
    export CERTS_DIR="$run_dir/certs"

    info "Staged files in $run_dir"
}

# ── Commands ─────────────────────────────────────────────────────────────────

cmd_start() {
    local freshen_up="$1"
    local import_sqlite="$2"

    check_prerequisites
    info "Container engine: $container_engine (compose: $compose_cmd)"

    if [ "$freshen_up" = "true" ]; then
        info "Freshen-up: tearing down existing stack and volumes"
        if [ -f "$env_file" ]; then
            load_config_from_env
            setup_compose_files
            # Guard: if persistent postgres data exists, it must be deleted together
            # with .env.production — never one without the other (orphaned data cannot
            # be accessed because its POSTGRES_PASSWORD lives in .env.production).
            if has_persistent_pg_data; then
                local pg_data_dir
                pg_data_dir="$(env_get "POSTGRES_DATA_DIR")"
                echo ""
                echo "  ── Persistent PostgreSQL data detected ─────────────────────────────────"
                echo "  .env.production and $pg_data_dir are a matched pair."
                echo "  Generating a new .env.production will make the existing database"
                echo "  permanently inaccessible (credentials will no longer match)."
                echo ""
                printf "  Delete $pg_data_dir AND continue with freshen-up? [y/N]: "
                local confirm_pg
                read -r confirm_pg
                if [[ "$confirm_pg" =~ ^[Yy] ]]; then
                    compose down -v 2>/dev/null || true
                    rm -rf "$pg_data_dir"
                    info "Removed persistent PostgreSQL data at $pg_data_dir"
                else
                    echo "Aborted. Your database and credentials are untouched."
                    exit 0
                fi
            else
                compose down -v 2>/dev/null || true
            fi
        fi
        local source_secret_key=""
        local source_allowed_hosts=""
        if [ -n "$import_sqlite" ]; then
            source_secret_key="$(extract_source_secret_key)"
            source_allowed_hosts="$(extract_source_env_value "ALLOWED_HOSTS")"
            if [ -z "$source_secret_key" ]; then
                echo ""
                echo "  ⚠  Could not extract SECRET_KEY from the source environment."
                echo "     PKI certificates (CA, server, client) use Fernet encryption"
                echo "     tied to SECRET_KEY. Without the original key, imported PKI"
                echo "     private keys will be unreadable."
                echo ""
                printf "  Source SECRET_KEY (leave empty to skip re-encryption): " >&2
                read -r source_secret_key
            fi
        fi
        create_env_file "$source_allowed_hosts"
    elif [ ! -f "$env_file" ]; then
        # Guard: if var/db/ exists without .env.production, the database is
        # inaccessible — its POSTGRES_PASSWORD is gone.  Refuse to create a new
        # env (which would generate a different password) until the user explicitly
        # runs --freshen-up, which will prompt before deleting var/db/ too.
        if [ -d "$prod_dir/var/db" ]; then
            die "Found $prod_dir/var/db/ but no $env_file.
  The database credentials (POSTGRES_PASSWORD) are stored in .env.production —
  without it the PostgreSQL data at var/db/ cannot be accessed.
  Options:
    • Restore .env.production from a backup to recover the database.
    • Run --freshen-up to wipe var/db/ and start fresh (data will be lost)."
        fi
        info "No .env.production found — creating one"
        create_env_file ""
    else
        info "Reusing existing $env_file (use --freshen-up to regenerate)"
    fi
    validate_and_repair_env
    load_config_from_env
    setup_compose_files
    info "Using env file: $env_file"

    # Warn if var/db/ exists but the current mode is not persistent —
    # this means data from a previous persistent run is stranded.
    if ! is_persistent_internal_db && [ -d "$prod_dir/var/db" ]; then
        echo ""
        echo "  ⚠  $prod_dir/var/db/ exists but POSTGRES_MODE is not 'persistent'."
        echo "     This data is from a previous persistent run and is no longer in use."
        echo "     Run --freshen-up or delete it manually to reclaim disk space."
        echo ""
    fi

    # Persistent postgres data directory: guard against orphaned state, then
    # create the directory if this is the first run.
    if is_persistent_internal_db; then
        local pg_data_dir
        pg_data_dir="$(env_get "POSTGRES_DATA_DIR")"
        if [ -z "$pg_data_dir" ]; then
            die "POSTGRES_MODE=persistent but POSTGRES_DATA_DIR is not set in $env_file.
  Run --freshen-up to reset from scratch, or add POSTGRES_DATA_DIR to $env_file."
        fi
        if [ -d "$pg_data_dir" ]; then
            info "Reusing existing PostgreSQL data at $pg_data_dir"
            echo "    PostgreSQL is running inside the container with data stored on the host."
            echo "    (to start fresh, run --freshen-up — you will be prompted before anything is deleted)"
        else
            mkdir -p "$pg_data_dir"
            info "Created PostgreSQL data directory at $pg_data_dir"
            echo "    PostgreSQL will run inside the container with data stored on the host."
        fi
        export POSTGRES_DATA_DIR="$pg_data_dir"
    fi

    verify_database_connectivity "$database_url"

    if [ "$freshen_up" = "true" ] || [ ! -f "$CERTS_DIR/fullchain.pem" ]; then
        create_self_signed_certs
    else
        info "Reusing existing certs in $CERTS_DIR/"
    fi

    # Ensure the persistent log directory exists and is writable by the
    # container's app user (which may have a remapped UID via user namespaces).
    mkdir -p "$prod_dir/var/log"
    chmod a+rwx "$prod_dir/var/log"
    export APP_LOGS_DIR="$prod_dir/var/log"

    # Stage nginx config and certs into run/ for Docker bind-mount access.
    # When the repo lives under a restricted home directory (e.g., 0700),
    # Docker cannot traverse the path to bind-mount files directly.
    stage_bind_mounts

    info "Building container image"
    compose build

    # podman-compose ≤1.0.6 does not propagate podman build exit codes; the
    # outer command exits 0 even when the inner build fails.  Verify the image
    # actually exists before proceeding so we fail fast with a clear message.
    if [ "$container_engine" = "podman" ]; then
        local app_image
        app_image="$(grep -E '^\s+image:' "$project_dir/docker-compose.yml" | grep -v '^#' | head -1 | sed 's/.*image: *//' | tr -d ' ')"
        if [ -n "$app_image" ] && ! podman image exists "$app_image" 2>/dev/null; then
            die "Image build failed — '$app_image' was not created. See build errors above."
        fi
    fi

    local compose_manual="$compose_cmd --env-file $env_file"
    local compose_files_display=""
    for f in "${compose_files[@]}"; do
        compose_files_display="$compose_files_display $f"
    done
    local log_hint="$compose_manual${compose_files_display} logs -f my-tracks"

    if [ -n "$import_sqlite" ]; then
        if ! is_internal_db; then
            die "--import-sqlite is only supported with containerized PostgreSQL"
        fi
        command -v uv >/dev/null 2>&1 || die "uv is required for --import-sqlite (used to run Django dumpdata).
  Install with:  curl -LsSf https://astral.sh/uv/install.sh | sh"

        info "Starting postgres for data import"
        compose up -d postgres

        info "Waiting for postgres to be healthy..."
        local pg_attempts=0
        while [ $pg_attempts -lt 30 ]; do
            if compose exec -T postgres pg_isready -U "$db_user" >/dev/null 2>&1; then
                break
            fi
            pg_attempts=$((pg_attempts + 1))
            sleep 2
        done
        [ $pg_attempts -lt 30 ] || die "PostgreSQL did not become healthy"

        info "Running database migrations..."
        compose run --rm --entrypoint "" -T my-tracks \
            python manage.py migrate --noinput \
            || die "Failed to run migrations"

        import_sqlite_to_postgres "$import_sqlite" "$source_secret_key"
    fi

    info "Starting stack"
    compose up -d

    local max_attempts=15
    info "Waiting for health check (${health_url}, up to $((max_attempts * 2))s)..."
    local attempts=0
    while [ $attempts -lt $max_attempts ]; do
        if curl -sk "$health_url" 2>/dev/null | grep -q '"status"'; then
            break
        fi
        attempts=$((attempts + 1))
        sleep 2
    done

    if [ $attempts -ge $max_attempts ]; then
        echo ""
        echo "WARNING: Health check did not pass within 30 seconds."
        echo ""
        echo "  ── Last 50 log lines ────────────────────────────────────────────────────"
        compose logs --no-log-prefix --tail=50 my-tracks 2>/dev/null || true
        echo "  ─────────────────────────────────────────────────────────────────────────"
        echo ""
        echo "Full logs: $log_hint"
        exit 1
    fi

    print_banner
}

cmd_freshen_up() {
    check_prerequisites

    # Load env early so we can check for persistent postgres mode.
    local has_persistent_data="false"
    local pg_data_dir=""
    if [ -f "$env_file" ]; then
        load_config_from_env
        if has_persistent_pg_data; then
            has_persistent_data="true"
            pg_data_dir="$(env_get "POSTGRES_DATA_DIR")"
        fi
    fi

    echo ""
    echo "  ── Freshen-up: the following will be permanently deleted ─────────────"
    local has_something="false"
    if [ -f "$env_file" ]; then
        if [ "$has_persistent_data" = "true" ]; then
            # Persistent data and .env.production must be treated as an atomic pair.
            # Show them grouped so the user understands they go together.
            echo "  • $env_file  (credentials including POSTGRES_PASSWORD)"
            echo "  • Docker volumes  (all container data)"
            echo ""
            echo "  ── Persistent PostgreSQL data (paired — must delete together) ──────────"
            echo "  • $pg_data_dir  (your database)"
            echo ""
            echo "  WARNING: Deleting .env.production without its paired postgres data directory"
            echo "  (or vice versa) will make the database permanently inaccessible."
            echo "  These two will be deleted together or not at all."
        else
            echo "  • $env_file  (credentials, secret key, ports)"
            echo "  • Docker volumes  (all container data, including database if containerized)"
        fi
        has_something="true"
    fi
    if [ -d "$prod_dir/var/certs" ]; then
        echo "  • $prod_dir/var/certs/  (TLS certificates)"
        has_something="true"
    fi
    if [ -d "$prod_dir/run" ]; then
        echo "  • $prod_dir/run/  (staged nginx/certs)"
        has_something="true"
    fi
    if [ -d "$prod_dir/var/log" ]; then
        echo "  • $prod_dir/var/log/  (application logs)"
        has_something="true"
    fi
    echo ""

    if [ "$has_something" = "false" ]; then
        info "Nothing to clean up — already at a clean slate."
        return
    fi

    if [ "$has_persistent_data" = "true" ]; then
        printf "  Delete .env.production AND $pg_data_dir together? [y/N]: "
    else
        printf "  Proceed? [y/N]: "
    fi
    read -r confirm
    [[ "$confirm" =~ ^[Yy] ]] || { echo "Aborted."; exit 0; }
    echo ""

    _removal_errors=()

    if [ -f "$env_file" ]; then
        info "Tearing down stack and volumes"
        setup_compose_files
        compose down -v 2>/dev/null || true
        try_rm ".env.production" "$env_file" && info "Removed $env_file"
        if [ "$has_persistent_data" = "true" ]; then
            try_rm "PostgreSQL data" "$pg_data_dir" \
                && info "Removed persistent PostgreSQL data at $pg_data_dir"
        fi
    fi
    [ -d "$prod_dir/var/certs" ] \
        && try_rm "certs" "$prod_dir/var/certs" && info "Removed certs/"
    try_rm "run dir" "$prod_dir/run"
    [ -d "$prod_dir/var/log" ] \
        && try_rm "application logs" "$prod_dir/var/log" && info "Removed application logs"
    cleanup_empty_var_dirs

    if flush_removal_errors; then
        info "Clean slate ready — run --start to configure and launch."
    else
        die "Some items could not be removed (see above). Fix the errors and retry."
    fi
}

cmd_stop() {
    check_prerequisites

    if [ -f "$env_file" ]; then
        load_config_from_env
        setup_compose_files
    else
        compose_files=("-f" "$project_dir/docker-compose.yml")
    fi

    _removal_errors=()

    info "Stopping stack and removing volumes"
    compose down -v
    try_rm "run dir" "$prod_dir/run"
    cleanup_empty_var_dirs
    flush_removal_errors || true  # report but don't abort — stack is already down

    if is_persistent_internal_db; then
        local pg_data_dir
        pg_data_dir="$(env_get "POSTGRES_DATA_DIR")"
        info "Stack stopped. PostgreSQL data preserved at $pg_data_dir"
        echo "    $env_file and $prod_dir/var/certs/ also preserved for next run."
    else
        info "Stack stopped. $env_file and $prod_dir/var/certs/ are preserved for next run."
    fi
}

# ── Main ─────────────────────────────────────────────────────────────────────

main() {
    local action=""
    local freshen_up="false"
    local import_sqlite=""

    while [ $# -gt 0 ]; do
        case "$1" in
            --start)      action="start"; shift ;;
            --stop)       action="stop"; shift ;;
            --freshen-up) freshen_up="true"; shift ;;
            --import-sqlite)
                shift
                if [ $# -gt 0 ] && [[ "$1" != --* ]]; then
                    if [[ "$1" = /* ]]; then
                        import_sqlite="$1"
                    else
                        import_sqlite="$PWD/$1"
                    fi
                    shift
                else
                    import_sqlite="$project_dir/db.sqlite3"
                fi
                [ -f "$import_sqlite" ] || die "SQLite database not found: $import_sqlite"
                ;;
            -h|--help)    usage; exit 0 ;;
            *)            die "Unknown option: $1. Use --help for usage." ;;
        esac
    done

    # --freshen-up alone means "clean up only"; with --start it regenerates and starts
    if [ "$freshen_up" = "true" ] && [ -z "$action" ]; then
        action="freshen-up"
    fi

    if [ -z "$action" ]; then
        usage
        exit 1
    fi

    case "$action" in
        start)      cmd_start "$freshen_up" "$import_sqlite" ;;
        stop)       cmd_stop ;;
        freshen-up) cmd_freshen_up ;;
    esac
}

main "$@"
